@inherits LayoutComponentBase
@inject IHttpContextAccessor HttpContextAccessor
@inject AuthenticationStateProvider AuthStateProvider
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@inject NavigationManager Nav
@implements IAsyncDisposable

<CascadingAuthenticationState>
    <div style="padding:12px 0;">
        <div style="width:420px;max-width:calc(100vw - 24px);margin:0;display:flex;align-items:center;justify-content:space-between;gap:12px;">
            <h1 style="margin:0;font-weight:800;letter-spacing:0.5px;background:linear-gradient(90deg,#ff3d00,#ffca28,#00c853,#2979ff,#d500f9);-webkit-background-clip:text;background-clip:text;color:transparent;text-shadow:0 1px 0 rgba(0,0,0,0.15);">Checkers</h1>
            @if (_isActuallyAuthenticated && !IsHomePage())
            {
                <button onclick="location.href='/logout'" style="min-width:120px;padding:6px 12px;border-radius:4px;border:1px solid #888;background:#f3f3f3;cursor:pointer;">Logout</button>
            }
            else
            {
                <!-- No logout button when not properly authenticated -->
            }
        </div>
    </div>

    <div style="width:420px;max-width:calc(100vw - 24px);margin:0;">
        @Body
    </div>
</CascadingAuthenticationState>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private AuthenticationState? _authState;
    private System.Timers.Timer? _authRefreshTimer;
    private bool _isActuallyAuthenticated = false;

    protected override async Task OnInitializedAsync()
    {
        // Initial authentication state check
        await RefreshAuthenticationState();
        
        // Set up a timer to periodically refresh authentication state
        _authRefreshTimer = new System.Timers.Timer(3000); // Check every 3 seconds
        _authRefreshTimer.Elapsed += async (sender, e) => await RefreshAuthenticationState();
        _authRefreshTimer.Start();
    }

    private async Task<bool> IsActuallyAuthenticated()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var isAuthenticated = authState?.User?.Identity?.IsAuthenticated ?? false;
            
            if (!isAuthenticated)
            {
                return false;
            }

            // Check for valid uid claim
            var uid = authState?.User?.FindFirst("uid")?.Value;
            var name = authState?.User?.Identity?.Name;
            
            // Only consider authenticated if both uid and name are present
            return !string.IsNullOrWhiteSpace(uid) && !string.IsNullOrWhiteSpace(name);
        }
        catch
        {
            return false;
        }
    }

    private bool IsHomePage()
    {
        try
        {
            var relative = Nav.ToBaseRelativePath(Nav.Uri);
            if (string.IsNullOrEmpty(relative)) return true;
            var path = relative.Split('?', '#')[0].Trim('/');
            return string.IsNullOrEmpty(path);
        }
        catch
        {
            return false;
        }
    }

    private async Task RefreshAuthenticationState()
    {
        try
        {
            var newAuthState = await AuthStateProvider.GetAuthenticationStateAsync();
            
            // Only update if the state actually changed to avoid unnecessary re-renders
            var oldIsAuthenticated = await IsActuallyAuthenticatedWithState(_authState);
            var newIsAuthenticated = await IsActuallyAuthenticatedWithState(newAuthState);
            
            if (oldIsAuthenticated != newIsAuthenticated)
            {
                _authState = newAuthState;
                _isActuallyAuthenticated = newIsAuthenticated;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AuthDebug] Error checking auth state: {ex.Message}");
            // If there's an error getting auth state, assume not authenticated
            if (_authState != null || _isActuallyAuthenticated)
            {
                _authState = null;
                _isActuallyAuthenticated = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task<bool> IsActuallyAuthenticatedWithState(AuthenticationState? authState)
    {
        try
        {
            var isAuthenticated = authState?.User?.Identity?.IsAuthenticated ?? false;
            if (!isAuthenticated) return false;

            var uid = authState?.User?.FindFirst("uid")?.Value;
            var name = authState?.User?.Identity?.Name;
            
            return !string.IsNullOrWhiteSpace(uid) && !string.IsNullOrWhiteSpace(name);
        }
        catch
        {
            return false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _authRefreshTimer?.Stop();
        _authRefreshTimer?.Dispose();
    }
}
