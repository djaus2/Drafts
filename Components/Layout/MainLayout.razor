@inherits LayoutComponentBase
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavigationManager

<div style="padding:12px 0;">
    <div style="width:420px;max-width:calc(100vw - 24px);margin:0;display:flex;align-items:center;justify-content:space-between;gap:12px;">
        <h1 style="margin:0;font-weight:800;letter-spacing:0.5px;background:linear-gradient(90deg,#ff3d00,#ffca28,#00c853,#2979ff,#d500f9);-webkit-background-clip:text;background-clip:text;color:transparent;text-shadow:0 1px 0 rgba(0,0,0,0.15);">Checkers</h1>
        @if (HttpContextAccessor.HttpContext?.User?.Identity?.IsAuthenticated == true && !ShouldHideLogoutButton())
        {
            <button onclick="clearLocalStorageAndLogout()" style="min-width:120px;padding:6px 12px;border-radius:4px;border:1px solid #888;background:#f3f3f3;cursor:pointer;">Logout</button>
        }
    </div>
</div>

<div style="width:420px;max-width:calc(100vw - 24px);margin:0;">
    @Body
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<script>
    function clearLocalStorageAndLogout() {
        console.log('[Logout] Disconnecting connections, clearing localStorage and redirecting to logout');
        
        // Disconnect any active voice/chat connections
        try {
            if (window.draftsVoice && typeof window.draftsVoice.disconnect === 'function') {
                window.draftsVoice.disconnect();
                console.log('[Logout] Disconnected draftsVoice');
            }
        } catch (e) {
            console.log('[Logout] Error disconnecting draftsVoice:', e);
        }
        
        // Clear localStorage
        localStorage.removeItem('voiceSettings');
        
        // Small delay to allow disconnections to complete
        setTimeout(() => {
            window.location.href = '/logout';
        }, 100);
    }
</script>

@code {
    private bool ShouldHideLogoutButton()
    {
        var uri = NavigationManager.Uri;
        return uri.EndsWith("/") || uri.Contains("/?") || uri.EndsWith("/home") || uri.Contains("/login");
    }
}
