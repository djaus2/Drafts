@inject NavigationManager Nav

@code {
    protected override void OnInitialized()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        // Ensure no double slash - if relative starts with /, don't add another one
        var cleanPath = relative.StartsWith("/") ? relative : "/" + relative;
        var returnUrl = Uri.EscapeDataString(cleanPath);
        Nav.NavigateTo($"/login?returnUrl={returnUrl}", forceLoad: true);
    }
}
