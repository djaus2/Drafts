            var now = DateTime.UtcNow;
            TimeSpan remaining;

            if (_game.KillAfterUtc.HasValue)
            {
                remaining = _game.KillAfterUtc.Value - now;
            }
            else
            {
                var max = TimeSpan.FromMinutes(Math.Max(1, _maxTimeoutMins));
                var idle = now - _game.LastTimeUtc;
                remaining = max - idle;
            }

            if (remaining < TimeSpan.Zero) remaining = TimeSpan.Zero;

            var mins = (int)remaining.TotalMinutes;
            return $"{mins}:{remaining.Seconds:00}";
        }
    }

