    private async Task QueueSpeakNewVoiceMessages(int fromChatIndex)
    {
        if (!_talkEnabled) return;
        if (_game is null) return;
        if (_currentUserId <= 0) return;
        if (_game.VoiceMuted) return;

        if (fromChatIndex < 0) fromChatIndex = 0;
        if (fromChatIndex < _lastVoiceSpokenChatIndex) fromChatIndex = _lastVoiceSpokenChatIndex;

        var messages = _game.ChatMessages;
        if (fromChatIndex >= messages.Count) return;

        _lastVoiceSpokenChatIndex = messages.Count;

        _ = InvokeAsync(async () =>
        {
            try
            {
                await JS.InvokeAsync<bool>("draftsVoice.unlockTts");
            }
            catch
            {
            }

            for (var i = Math.Max(0, fromChatIndex); i < messages.Count; i++)
            {
                var m = messages[i];
                if (m is null) continue;
                if (m.SenderUserId == _currentUserId) continue;

                var t = m.Text ?? string.Empty;
                if (!t.StartsWith(VoicePrefix, StringComparison.OrdinalIgnoreCase)) continue;

                var payload = t.Substring(VoicePrefix.Length).Trim();
                if (string.IsNullOrWhiteSpace(payload)) continue;

                string? voiceKey = null;
                string? voiceLanguage = null;
                string? voiceRegion = null;
                try
                {
                    voiceKey = _game?.GetPreferredTtsVoiceForUserId(m.SenderUserId);
                    voiceLanguage = _game?.GetPreferredTtsLanguageForUserId(m.SenderUserId);
                    voiceRegion = _game?.GetPreferredTtsRegionForUserId(m.SenderUserId);
                }
                catch
                {
                    voiceKey = null;
                    voiceLanguage = null;
                    voiceRegion = null;
                }

                if (!_talkEnabled) break;

                _ttsDebug = $"msg#{i} len={payload?.Length}: {payload?.Substring(0, Math.Min(80, payload?.Length ?? 0))}";
                await InvokeAsync(StateHasChanged);
                // Debug: log what we're about to speak
                await JS.InvokeVoidAsync("console.log", $"[TTS] Speaking msg #{i}, payload.Length={payload?.Length ?? 0}, payload={payload?.Substring(0, Math.Min(100, payload?.Length ?? 0))}");

                try
                {
                    var voiceLabel = _isPhoneClient
                        ? await JS.InvokeAsync<string>("draftsVoice.speakDefaultAndDescribe", payload)
                        : await JS.InvokeAsync<string>("draftsVoice.speakAndDescribe", payload, voiceKey, voiceLanguage, voiceRegion);
                    if (string.IsNullOrWhiteSpace(voiceLabel)) voiceLabel = "Default voice";

                    await JS.InvokeVoidAsync(
                        "console.log",
                        $"[TTS] Received msg #{i} from user {m.SenderUserId} using voice: {voiceLabel}; phoneReceiver={_isPhoneClient}");

                    var usedDefaultVoice = voiceLabel.StartsWith("Default voice", StringComparison.OrdinalIgnoreCase);
                    string diagnosticSuffix = "";

                    if (usedDefaultVoice && !_isPhoneClient)
                    {
                        try
                        {
                            var inspect = await JS.InvokeAsync<VoiceInspectResult>("draftsVoice.inspectVoiceMatch", voiceKey, voiceLanguage, voiceRegion);
                            if (inspect is not null)
                            {
                                var keyText = string.IsNullOrWhiteSpace(inspect.preferredKey) ? "(empty)" : inspect.preferredKey;
                                var matchedText = inspect.matched
                                    ? $"matched={inspect.matchedLabel}"
                                    : "matched=(none)";
                                diagnosticSuffix = $" key={keyText}; voices={inspect.voicesCount}; {matchedText}";
                            }
                        }
                        catch
                        {
                        }
                    }

                    _ttsStatusVersion++;
                    var v = _ttsStatusVersion;
                    _ttsStatus = usedDefaultVoice
                        ? $"Speaking: Default{diagnosticSuffix}"
                        : $"Speaking: {voiceLabel}";
                    await InvokeAsync(StateHasChanged);

                    _ = InvokeAsync(async () =>
                    {
                        try
                        {
                            await Task.Delay(20000);
                            if (_ttsStatusVersion != v) return;
                            _ttsStatus = "";
                            await InvokeAsync(StateHasChanged);
                        }
                        catch
                        {
                        }
                    });
                }
                catch
                {
                    var ok = _isPhoneClient
                        ? await JS.InvokeAsync<bool>("draftsVoice.speakDefault", payload)
                        : await JS.InvokeAsync<bool>("draftsVoice.speak", payload, voiceKey, voiceLanguage, voiceRegion);
                    _ = ok;
                }

                try
                {
                    UpdateVoiceStatusFromGame();
                    await InvokeAsync(StateHasChanged);
                }
                catch
                {
                }
            }
        });
    }

