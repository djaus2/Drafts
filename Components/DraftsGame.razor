    private void BeginJoin(string id)
    {
        if (_currentUserId <= 0)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }
        if (_joined && _connected && string.Equals(_gameId, id, StringComparison.Ordinal))
        {
            _game = GameService.GetGame(id);
            _status = "";

            GameService.GameUpdated -= OnGameUpdated;
            GameService.GameUpdated += OnGameUpdated;
            _message = GetConnectedMessage();
            return;
        }

        _status = "Joining...";
        GameService.GameUpdated -= OnGameUpdated;
        var player = GameService.TryJoinGame(id, _currentUserId, _currentUserName);
        if (player == -1)
        {
            var existing = GameService.GetActiveGameIdForUser(_currentUserId);
            if (!string.IsNullOrWhiteSpace(existing))
            {
                _status = "You are already in another game. Redirecting...";
                _connected = false;
                _joined = false;
                _ = InvokeAsync(StateHasChanged);
                Nav.NavigateTo($"/drafts?gameId={existing}", forceLoad: false);
                return;
            }

            _status = "You are already in another game.";
            _connected = false;
            return;
        }
        if (player == 0)
        {
            Nav.NavigateTo("/", forceLoad: true);
            return;
        }
        _playerNumber = player;
        _game = GameService.GetGame(id);

        try
        {
            if (!string.IsNullOrWhiteSpace(_gameId) && _currentUserId > 0)
            {
                GameService.SetPreferredTtsSettingsForUser(_gameId, _currentUserId, _preferredTtsVoiceKey, _preferredTtsLanguage, _preferredTtsRegion);
            }
        }
        catch
        {
        }

        _connected = true;
        _joined = true;
        _status = "";

        EnsureUiTimer();

        _chatDisplayStartIndex = 0;
        _chatInText = FormatChat(_game, _chatDisplayStartIndex);
        _lastChatCount = _game?.ChatMessages?.Count ?? 0;
        _lastVoiceSpokenChatIndex = _lastChatCount;
        _chatScrollPending = true;
        GameService.GameUpdated += OnGameUpdated;
        _message = GetConnectedMessage();
        return;
    }

    private void OnGameUpdated(string id)
    {
        if (id != _gameId) return;
        _game = GameService.GetGame(id);

        UpdateVoiceStatusFromGame();

        if (_game is not null
            && _game.ForcedJumpFromR.HasValue
            && _game.ForcedJumpFromC.HasValue
            && (IsAdminControllingGame() || _game.CurrentTurn == _playerNumber))
        {
            _selectedR = _game.ForcedJumpFromR.Value;
            _selectedC = _game.ForcedJumpFromC.Value;
            _message = $"Must continue jumping with {_selectedR},{_selectedC}.";
        }

        if (_game is not null)
        {
            if (_lastGameState != _game.State || _lastWinnerPlayer != _game.WinnerPlayer)
            {
                if (_game.State == DraftsService.GameState.Finished && _lastGameState != DraftsService.GameState.Finished)
                {
                    _showGameOverOverlay = true;
                    _message = GameResultText;
                }

                _lastGameState = _game.State;
                _lastWinnerPlayer = _game.WinnerPlayer;
            }
        }

        if (_connected
            && _game is not null
            && string.IsNullOrWhiteSpace(_message)
            && !_game.ForcedJumpFromR.HasValue
            && _game.State != DraftsService.GameState.Finished
            && _game.State != DraftsService.GameState.Abandoned)
        {
            _message = GetConnectedMessage();
        }

        var chatCount = _game?.ChatMessages?.Count ?? 0;
        if (chatCount != _lastChatCount)
        {
            var priorChatCount = _lastChatCount;
            _lastChatCount = chatCount;
            _chatInText = FormatChat(_game, _chatDisplayStartIndex);
            _chatScrollPending = true;

            if (_talkEnabled)
            {
                QueueSpeakNewVoiceMessages(priorChatCount);
            }
        }

        if (_game is null)
        {
            _ = InvokeAsync(async () =>
            {
                if (_gameClosedNotified) return;
                _gameClosedNotified = true;

                GameService.GameUpdated -= OnGameUpdated;
                _connected = false;
                _joined = false;
                _gameId = null;

                try
                {
                    await JS.InvokeVoidAsync("alert", "Game was closed.");
                }
                catch (TaskCanceledException)
                {
                }
                catch (ObjectDisposedException)
                {
                }
                catch (Microsoft.JSInterop.JSDisconnectedException)
                {
                }

                try
                {
                    Nav.NavigateTo("/player", forceLoad: true);
                }
                catch
                {
                }
            });
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_chatWired)
        {
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("draftsChat.wireEnterToSend", _chatOutRef, _dotNetRef);
                _chatWired = true;
            }
            catch
            {
            }
        }

        if (_chatScrollPending)
        {
            try
            {
                _chatScrollPending = false;
                await JS.InvokeVoidAsync("draftsChat.scrollToBottom", _chatInRef);
                await JS.InvokeVoidAsync("draftsChat.scrollToBottom", _chatOutRef);
            }
            catch
            {
            }
        }

        if (firstRender)
        {
            try
            {
                await JS.InvokeAsync<bool>("draftsVoice.installTtsUnlocker");
                _voiceSupported = await JS.InvokeAsync<bool>("draftsVoice.isSupported");
                _voiceSupportChecked = true;
                _talkEnabled = _voiceSupported;
                _voiceStatus = _voiceSupported ? "Hold to talk" : "Talk not supported in this browser";

                try
                {
                    _isPhoneClient = await JS.InvokeAsync<bool>("draftsVoice.isProbablyPhone");
                }
                catch
                {
                    _isPhoneClient = false;
                }

                if (_isPhoneClient)
                {
                    _preferredTtsVoiceKey = "";
                    _preferredTtsLanguage = "";
                    _preferredTtsRegion = "";
                    try
                    {
                        if (!string.IsNullOrWhiteSpace(_gameId) && _currentUserId > 0)
                        {
                            GameService.SetPreferredTtsSettingsForUser(_gameId, _currentUserId, null, null, null);
                        }
                    }
                    catch
                    {
                    }
                }

                await InvokeAsync(StateHasChanged);
            }
            catch
            {
                _voiceSupported = false;
                _voiceSupportChecked = true;
                _voiceStatus = "Talk not supported";
            }
        }
    }

