    private string FormatChat(Drafts.Services.DraftsGame? game)
    {
        return FormatChat(game, 0);
    }

    private string FormatChat(Drafts.Services.DraftsGame? game, int startIndex)
    {
        if (game is null) return "";
        if (game.ChatMessages.Count == 0) return "";

        if (startIndex < 0) startIndex = 0;
        if (startIndex >= game.ChatMessages.Count) return "";

        var hideVoice = _hideVoiceInChat;
        var lines = game.ChatMessages
            .Skip(startIndex)
            .Where(m => !hideVoice || !m.Text.StartsWith(VoicePrefix, StringComparison.OrdinalIgnoreCase))
            .Select(m => $"{m.SenderName}: {m.Text ?? string.Empty}");

        return string.Join("\n", lines);
    }

