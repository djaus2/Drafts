        {
            if (int.TryParse(creatorRaw, out var parsed)) creatorPlayerNumber = parsed;
        }

        var adminMode = false;
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("admin", out var adminRaw))
        {
            adminMode = string.Equals(adminRaw.ToString(), "1", StringComparison.OrdinalIgnoreCase)
                || string.Equals(adminRaw.ToString(), "true", StringComparison.OrdinalIgnoreCase);
        }

        if (adminMode && !_isAdmin)
        {
            adminMode = false;
        }

        _gameId = GameService.CreateGame(_currentUserId, _currentUserName, creatorPlayerNumber, adminMode);
        Nav.NavigateTo($"/drafts?gameId={_gameId}", forceLoad: false);
        BeginJoin(_gameId);
