        if (_chatScrollPending)
        {
            _chatScrollPending = false;
            await JS.InvokeVoidAsync("draftsChat.scrollToBottom", _chatInRef);
            await JS.InvokeVoidAsync("draftsChat.scrollToBottom", _chatOutRef);
