    private void BeginJoin(string id)
    {
        if (_currentUserId <= 0)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }
        if (_joined && _connected && string.Equals(_gameId, id, StringComparison.Ordinal))
        {
            _game = GameService.GetGame(id);
            _status = "";

            GameService.GameUpdated -= OnGameUpdated;
            GameService.GameUpdated += OnGameUpdated;
            _message = "Connected.";
            return;
        }

        _status = "Joining...";
        GameService.GameUpdated -= OnGameUpdated;
        var player = GameService.TryJoinGame(id, _currentUserId);
        if (player == -1)
        {
            var existing = GameService.GetActiveGameIdForUser(_currentUserId);
            if (!string.IsNullOrWhiteSpace(existing))
            {
                _status = "You are already in another game. Redirecting...";
                _connected = false;
                _joined = false;
                _ = InvokeAsync(StateHasChanged);
                Nav.NavigateTo($"/drafts?gameId={existing}", forceLoad: false);
                return;
            }

            _status = "You are already in another game.";
            _connected = false;
            return;
        }
        if (player == 0)
        {
            _status = "Unable to join (game full or not found).";
            _connected = false;
            return;
        }
        _playerNumber = player;
        _game = GameService.GetGame(id);

        _connected = true;
        _joined = true;
        _status = "";

        EnsureUiTimer();

        _chatDisplayStartIndex = 0;
        _chatInText = FormatChat(_game, _chatDisplayStartIndex);
        _lastChatCount = _game?.ChatMessages?.Count ?? 0;
        _lastVoiceSpokenChatIndex = _lastChatCount;
        _chatScrollPending = true;
        GameService.GameUpdated += OnGameUpdated;
        _message = "Connected.";
        return;
    }

    private void OnGameUpdated(string id)
    {
        if (id != _gameId) return;
        _game = GameService.GetGame(id);

        UpdateVoiceStatusFromGame();

        if (_game is not null
            && _game.ForcedJumpFromR.HasValue
            && _game.ForcedJumpFromC.HasValue
            && (IsAdminControllingGame() || _game.CurrentTurn == _playerNumber))
        {
            _selectedR = _game.ForcedJumpFromR.Value;
            _selectedC = _game.ForcedJumpFromC.Value;
            _message = $"Must continue jumping with {_selectedR},{_selectedC}.";
        }

        if (_game is not null)
        {
            if (_lastGameState != _game.State || _lastWinnerPlayer != _game.WinnerPlayer)
            {
                if (_game.State == DraftsService.GameState.Finished && _lastGameState != DraftsService.GameState.Finished)
                {
                    _showGameOverOverlay = true;
                    _message = GameResultText;
                }

                _lastGameState = _game.State;
                _lastWinnerPlayer = _game.WinnerPlayer;
            }
        }

        var chatCount = _game?.ChatMessages?.Count ?? 0;
        if (chatCount != _lastChatCount)
        {
            var priorChatCount = _lastChatCount;
            _lastChatCount = chatCount;
            _chatInText = FormatChat(_game, _chatDisplayStartIndex);
            _chatScrollPending = true;

            if (_talkEnabled)
            {
                QueueSpeakNewVoiceMessages(priorChatCount);
            }
        }

        if (_game is null)
        {
            _ = InvokeAsync(async () =>
            {
                if (_gameClosedNotified) return;
                _gameClosedNotified = true;

                GameService.GameUpdated -= OnGameUpdated;
                _connected = false;
                _joined = false;
                _gameId = null;

                try
                {
                    await JS.InvokeVoidAsync("alert", "Game was closed.");
                }
                catch (TaskCanceledException)
                {
                }
                catch (ObjectDisposedException)
                {
                }
                catch (Microsoft.JSInterop.JSDisconnectedException)
                {
                }

                try
                {
                    Nav.NavigateTo("/player", forceLoad: true);
                }
                catch
                {
                }
            });
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_chatWired)
