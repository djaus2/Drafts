    private async Task OnCellClick(int r, int c)
    {
        if (!CanInteractWithBoard())
        {
            if (_game is not null && _game.State == DraftsService.GameState.Finished)
            {
                _message = GameResultText;
            }
            else if (_game is not null && _game.State == DraftsService.GameState.Abandoned)
            {
                _message = "Game was abandoned.";
            }
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_isDragging || _suppressNextClick)
        {
            _suppressNextClick = false;
            return;
        }

        if (_game == null)
        {
            _message = "No game loaded.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var cell = _game.Board[r, c];

        if (_game.ForcedJumpFromR.HasValue && _game.ForcedJumpFromC.HasValue && _game.CurrentTurn == _playerNumber)
        {
            var mustR = _game.ForcedJumpFromR.Value;
            var mustC = _game.ForcedJumpFromC.Value;
            if (cell != 0 && CanInteractWithPiece(cell) && (r != mustR || c != mustC))
            {
                _message = $"Must continue jumping with {mustR},{mustC}.";
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        var belongs = (cell != 0) && CanInteractWithPiece(cell);

        if (!_selectedR.HasValue)
        {
            if (cell == 0)
            {
                _message = $"Empty square ({r},{c}). Select one of your pieces.";
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (!belongs)
            {
                _message = $"That's not your piece (cell={cell}) — you are player {_playerNumber}.";
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (!IsAdminControllingGame()
                && _game.ForcedJumpFromR.HasValue
                && _game.ForcedJumpFromC.HasValue
                && _game.CurrentTurn != _playerNumber)
            {
                if (string.IsNullOrWhiteSpace(_gameId)) return;
                var (okClaim, msgClaim) = GameService.ClaimTurn(_gameId!, _playerNumber);
                _message = okClaim ? "" : (msgClaim ?? "Cannot claim turn");
                _game = GameService.GetGame(_gameId!);
                _selectedR = null;
                _selectedC = null;
                await InvokeAsync(StateHasChanged);
                return;
            }

            ClearLastMoveHighlightIfNextPlayerSelecting();

            _selectedR = r;
            _selectedC = c;
            _message = $"Selected {_selectedR},{_selectedC} (cell={cell}). Click destination.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var fr = _selectedR!.Value;
        var fc = _selectedC!.Value;

        if (fr == r && fc == c)
        {
            _selectedR = null; _selectedC = null;
            _message = "Selection cleared.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        (bool ok, string? msg) result;
        if (IsAdminControllingGame())
        {
            result = GameService.MakeMoveAsAdmin(_gameId!, fr, fc, r, c);
        }
        else
        {
            result = GameService.MakeMove(_gameId!, _playerNumber, fr, fc, r, c);
        }
        var (ok, msg) = result;
        _message = ok ? "" : msg ?? "Invalid move";

        if (ok && !string.IsNullOrWhiteSpace(_gameId))
        {
            _game = GameService.GetGame(_gameId);
        }

        if (ok
            && _game is not null
            && _game.ForcedJumpFromR.HasValue
            && _game.ForcedJumpFromC.HasValue
            && (IsAdminControllingGame() || _game.CurrentTurn == _playerNumber))
        {
            _selectedR = _game.ForcedJumpFromR.Value;
            _selectedC = _game.ForcedJumpFromC.Value;
            _message = $"Must continue jumping with {_selectedR},{_selectedC}.";
        }
        else
        {
            _selectedR = null;
            _selectedC = null;
        }
        await InvokeAsync(StateHasChanged);
    }

    private void OnPointerDownPiece(PointerEventArgs e, int r, int c)
    {
        if (_game == null) return;

        if (!CanInteractWithBoard())
        {
            if (_game is not null && _game.State == DraftsService.GameState.Finished)
            {
                _message = GameResultText;
            }
            else if (_game is not null && _game.State == DraftsService.GameState.Abandoned)
            {
                _message = "Game was abandoned.";
            }
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        var cell = _game.Board[r, c];
        if (cell == 0 || !CanInteractWithPiece(cell)) return;

        if (!IsAdminControllingGame()
            && _game.ForcedJumpFromR.HasValue
            && _game.ForcedJumpFromC.HasValue
            && _game.CurrentTurn != _playerNumber)
        {
            if (string.IsNullOrWhiteSpace(_gameId)) return;
            var (okClaim, msgClaim) = GameService.ClaimTurn(_gameId!, _playerNumber);
            _message = okClaim ? "" : (msgClaim ?? "Cannot claim turn");
            _game = GameService.GetGame(_gameId!);
            _isDragging = false;
            _dragFromR = null;
            _dragFromC = null;
            _dragHoverR = null;
            _dragHoverC = null;
            _selectedR = null;
            _selectedC = null;
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        if (_game.ForcedJumpFromR.HasValue && _game.ForcedJumpFromC.HasValue && _game.CurrentTurn == _playerNumber)
        {
            var mustR = _game.ForcedJumpFromR.Value;
            var mustC = _game.ForcedJumpFromC.Value;
            if (r != mustR || c != mustC)
            {
                _message = $"Must continue jumping with {mustR},{mustC}.";
                _ = InvokeAsync(StateHasChanged);
                return;
            }
        }

        ClearLastMoveHighlightIfNextPlayerSelecting();

        if (e.ShiftKey)
        {
            _isDragging = false;
            _dragFromR = null;
            _dragFromC = null;
            _dragHoverR = null;
            _dragHoverC = null;
            _suppressNextClick = true;
            _selectedR = r;
            _selectedC = c;
            _message = $"Selected {r},{c} (cell={cell}). Click destination.";
            return;
        }

        if (string.Equals(e.PointerType, "touch", StringComparison.OrdinalIgnoreCase))
        {
            _isDragging = false;
            _dragFromR = null;
            _dragFromC = null;
            _dragHoverR = null;
            _dragHoverC = null;
            _suppressNextClick = true;
            _selectedR = r;
            _selectedC = c;
            _message = $"Selected {r},{c} (cell={cell}). Tap destination.";
            return;
        }

        _isDragging = true;
        _dragFromR = r;
        _dragFromC = c;
        _dragHoverR = r;
        _dragHoverC = c;
        _selectedR = r;
        _selectedC = c;
        _message = $"Dragging from ({r},{c}). Release on destination.";
    }

    private void OnPointerEnterCell(int r, int c)
    {
        if (!_isDragging) return;
        _dragHoverR = r;
        _dragHoverC = c;
    }

    private async Task OnPointerUpCell(int r, int c)
    {
        if (!_isDragging)
        {
            return;
        }

        if (!CanInteractWithBoard())
        {
            if (_game is not null && _game.State == DraftsService.GameState.Finished)
            {
                _message = GameResultText;
            }
            else if (_game is not null && _game.State == DraftsService.GameState.Abandoned)
            {
                _message = "Game was abandoned.";
            }
            _isDragging = false;
            _dragFromR = null;
            _dragFromC = null;
            _dragHoverR = null;
            _dragHoverC = null;
            _selectedR = null;
            _selectedC = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_game is not null && _game.State == DraftsService.GameState.Finished)
        {
            _message = GameResultText;
            _suppressNextClick = true;
            _isDragging = false;
            _dragFromR = null;
            _dragFromC = null;
            _dragHoverR = null;
            _dragHoverC = null;
            _selectedR = null;
            _selectedC = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_game == null || !_dragFromR.HasValue || !_dragFromC.HasValue)
        {
            _isDragging = false;
            _dragFromR = null;
            _dragFromC = null;
            _selectedR = null;
            _selectedC = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var fr = _dragFromR.Value;
        var fc = _dragFromC.Value;

        if (fr == r && fc == c)
        {
            _suppressNextClick = true;
            _isDragging = false;
            _dragFromR = null;
            _dragFromC = null;
            _dragHoverR = null;
            _dragHoverC = null;
            _selectedR = null;
            _selectedC = null;
            _message = "";
            await InvokeAsync(StateHasChanged);
            return;
        }

        (bool ok, string? msg) result;
        if (IsAdminControllingGame())
        {
            result = GameService.MakeMoveAsAdmin(_gameId!, fr, fc, r, c);
        }
        else
        {
            result = GameService.MakeMove(_gameId!, _playerNumber, fr, fc, r, c);
        }
        var (ok, msg) = result;
        _message = ok ? "" : msg ?? "Invalid move";

        if (ok && !string.IsNullOrWhiteSpace(_gameId))
        {
            _game = GameService.GetGame(_gameId);
        }

        if (ok
            && _game is not null
            && _game.ForcedJumpFromR.HasValue
            && _game.ForcedJumpFromC.HasValue
            && (IsAdminControllingGame() || _game.CurrentTurn == _playerNumber))
        {
            _selectedR = _game.ForcedJumpFromR.Value;
            _selectedC = _game.ForcedJumpFromC.Value;
            _message = $"Must continue jumping with {_selectedR},{_selectedC}.";
        }
        else
        {
            _selectedR = null;
            _selectedC = null;
        }

        _suppressNextClick = true;
        _isDragging = false;
        _dragFromR = null;
        _dragFromC = null;
        _dragHoverR = null;
        _dragHoverC = null;

        await InvokeAsync(StateHasChanged);
    }

    private static bool BelongsToPlayer(int piece, int player)
    {
        if (player == 1) return piece == 1 || piece == 3;
        return piece == 2 || piece == 4;
    }

    private bool IsAdminControllingGame()
    {
        return _isAdmin && _game is not null && _game.AdminMode;
    }

    private bool CanInteractWithBoard()
    {
        if (!_connected) return false;
        if (_game is null) return false;
        if (_game.State == DraftsService.GameState.Finished || _game.State == DraftsService.GameState.Abandoned) return false;
        if (_game.AdminMode && !_isAdmin) return false;
        return true;
    }

    private bool CanInteractWithPiece(int piece)
    {
        if (!CanInteractWithBoard()) return false;
        if (IsAdminControllingGame()) return true;
        return BelongsToPlayer(piece, _playerNumber);
    }

    private bool IsLastMoveTo(int r, int c)
    {
        if (_game is null) return false;
        if (!_game.LastMoveToR.HasValue || !_game.LastMoveToC.HasValue) return false;
        return _game.LastMoveToR.Value == r && _game.LastMoveToC.Value == c;
    }

    private bool IsLastMoveCaptured(int r, int c)
    {
        if (_game is null) return false;
        if (_game.LastMoveCapturedSquares.Count == 0) return false;
        return _game.LastMoveCapturedSquares.Any(p => p.R == r && p.C == c);
    }

    private void ClearLastMoveHighlightIfNextPlayerSelecting()
    {
        if (_game is null) return;
        if (!_game.LastMoveToR.HasValue || !_game.LastMoveToC.HasValue) return;

        // After a move, CurrentTurn flips. Only clear when the next player starts selecting a piece.
        // For admin-mode games, allow admin to clear as well.
        if (!IsAdminControllingGame() && _game.CurrentTurn != _playerNumber) return;

        if (string.IsNullOrWhiteSpace(_gameId)) return;
        GameService.ClearLastMoveHighlight(_gameId);
    }

    private void DismissGameOverOverlay()
    {
        _showGameOverOverlay = false;
    }

    private void OnCellRightClick(MouseEventArgs e, int r, int c)
    {
        if (!IsAdminControllingGame()) return;
        if (string.IsNullOrWhiteSpace(_gameId)) return;

        var (ok, msg) = GameService.DeletePieceAsAdmin(_gameId!, r, c);
        _message = ok ? "" : msg ?? "Delete failed";
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnVoiceTranscript(string text)
    {
        // Note: _pttHeld may already be false since JS flush is delayed after button release
        if (string.IsNullOrWhiteSpace(_gameId)) return Task.CompletedTask;
        if (_currentUserId <= 0) return Task.CompletedTask;
        if (string.IsNullOrWhiteSpace(text)) return Task.CompletedTask;
        if (_game?.VoiceMuted == true) return Task.CompletedTask;

        var clean = text.Trim();
        // Voice preference is shared via SetPreferredTtsVoiceForUser on join, no need for metadata in messages
        GameService.AddChatMessage(_gameId, _currentUserId, _currentUserName, VoicePrefix + clean);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnVoiceError(string error)
    {
        var text = (error ?? string.Empty).Trim();
        _voiceStatus = string.IsNullOrWhiteSpace(text)
            ? "Mic error"
            : $"Mic error: {text}";
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnVoiceEnded()
    {
        return Task.CompletedTask;
    }

    private async Task OnTalkPointerDown()
    {
        if (!_voiceSupported) return;
        if (!_talkEnabled) return;
        if (_pttHeld) return;
        if (IsVoiceFloorHeldByOther) return;

        _pttHeld = true;
        _voiceStatus = "Talking…";

        if (!string.IsNullOrWhiteSpace(_gameId) && _currentUserId > 0)
        {
            GameService.TryAcquireVoiceFloor(_gameId, _currentUserId, _currentUserName);
        }

        _voiceDotNetRef ??= DotNetObjectReference.Create(this);

        try
        {
            await JS.InvokeAsync<bool>("draftsVoice.start", _voiceDotNetRef);
        }
        catch
        {
        }

        _voiceHoldRenewTimer?.Dispose();
        _voiceHoldRenewTimer = new System.Threading.Timer(_ =>
        {
            if (!_pttHeld) return;
            if (string.IsNullOrWhiteSpace(_gameId)) return;
            if (_currentUserId <= 0) return;
            GameService.TryAcquireVoiceFloor(_gameId, _currentUserId, _currentUserName);
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnTalkPointerUp()
    {
        if (!_pttHeld) return;
        _pttHeld = false;

        _voiceHoldRenewTimer?.Dispose();
        _voiceHoldRenewTimer = null;

        if (!string.IsNullOrWhiteSpace(_gameId) && _currentUserId > 0)
        {
            GameService.ReleaseVoiceFloor(_gameId, _currentUserId);
        }

        try
        {
            await JS.InvokeAsync<bool>("draftsVoice.stop");
        }
        catch
        {
        }

        UpdateVoiceStatusFromGame();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnTalkPointerCancel()
    {
        await OnTalkPointerUp();
    }

    private async Task OnTalkPointerLeave()
    {
        await OnTalkPointerUp();
    }

    public void Dispose()
    {
        GameService.GameUpdated -= OnGameUpdated;
        try
        {
            _uiTimer?.Dispose();
        }
        catch
        {
        }

        try
        {
            _voiceHoldRenewTimer?.Dispose();
        }
        catch
        {
        }

        try
        {
            if (_pttHeld && !string.IsNullOrWhiteSpace(_gameId) && _currentUserId > 0)
            {
                GameService.ReleaseVoiceFloor(_gameId, _currentUserId);
            }
        }
        catch
        {
        }

        _dotNetRef?.Dispose();
    }
}