    private async Task SendChat()
    {
        if (string.IsNullOrWhiteSpace(_gameId)) return;
        if (_currentUserId <= 0) return;

        var text = _chatOutText;
        if (string.IsNullOrWhiteSpace(text)) return;

        var ok = GameService.AddChatMessage(_gameId, _currentUserId, _currentUserName, text);
        if (ok)
        {
            _chatOutText = "";
            _chatScrollPending = true;
            await InvokeAsync(StateHasChanged);
        }
