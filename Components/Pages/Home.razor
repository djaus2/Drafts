@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@* @attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Player,Admin")]
 *@
@using Draughts.Services
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject SettingsService Settings
@inject AuthenticationStateProvider AuthStateProvider
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@inject IHttpContextAccessor HttpContextAccessor

<PageTitleHeading Title="@($"Checkers online V{Version}")" HeadingLevel="2" />

<br />

<p>Play Draughts or Checkers with a friend online</p>

<button @onclick="Start">Login to start or join a Game</button>

<br />

<img src="Images/TheBoard.png" width="250"/>

<br />
<br />

<div style="max-width:400px;padding:12px;border:1px solid #ccc;background-color:lightgreen;">
    <h4 style="margin-top:0;"><font color="blue">Game Timeout Settings</font></h4>
    <div style="font-size:14px;line-height:1.6;">
        <div><strong>Move timeout:</strong> @_maxMoveTimeoutMins minutes</div>
        <div><strong>Max game time:</strong> @_maxGameTimeMins minutes</div>
        <div><strong>Max game start wait:</strong> @_maxGameStartWaitTimeMins minutes</div>
        <div><strong>Max login session:</strong> @_maxLoginHrs hours</div>
        <div><strong>Multi-jump Other player can butt in after:</strong> @_multiJumpGraceSeconds secs</div>
    </div>
</div>

<div style="max-width:400px;padding:12px;border:1px solid #ccc;background-color:beige">
    <h4 style="margin-top:0;"><font color="purple">Players and Playing</font></h4>
    <div style="font-size:14px;line-height:1.6;">
        <div><strong>Players: </strong>Bob, Ted, Carol and Alice </div>
        <div><strong>Pin for login: </strong>All pins are 9999</div>
        <div><strong>Group Bob-Carol: </strong>Bob and Carol can play</div>
        <div><strong>Group Ted-Alice: </strong>Ted and Alice can play</div>
        <div><strong><i>One starts the game, other joins</i></strong> </div>
        <div><strong><i>Note timeouts as above</i></strong> </div>
    </div>
</div>

@code{
    private int _maxMoveTimeoutMins = 5;
    private int _maxGameTimeMins = 30;
    private int _maxGameStartWaitTimeMins = 30;
    private int _maxLoginHrs = 4;
    private double _multiJumpGraceSeconds = 2.0;

    protected override async Task OnInitializedAsync()
    {
        _maxMoveTimeoutMins = await Settings.GetMaxMoveTimeoutMinsAsync();
        _maxGameTimeMins = await Settings.GetMaxGameTimeMinsAsync();
        _maxGameStartWaitTimeMins = await Settings.GetMaxGameStartWaitTimeMinsAsync();
        _maxLoginHrs = await Settings.GetMaxLoginHrsAsync();
        _multiJumpGraceSeconds = await Settings.GetMultiJumpGraceSecondsAsync();
    }

    private string Version 
    {
        get
        {
            try
            {
                // Read version from auth.json
                var jsonPath = Path.Combine(Directory.GetCurrentDirectory(), "auth.json");
                if (File.Exists(jsonPath))
                {
                    var jsonContent = File.ReadAllText(jsonPath);
                    using var document = JsonDocument.Parse(jsonContent);
                    if (document.RootElement.TryGetProperty("version", out var versionElement))
                    {
                        return versionElement.GetString() ?? "7.0.0";
                    }
                }
            }
            catch
            {
                // Fallback if JSON reading fails
            }
            return "7.0.0"; // Fallback version
        }
    }

    private void Start()
    {
        Nav.NavigateTo($"/login");
    }
}