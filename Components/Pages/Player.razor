@page "/player"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Player,Admin")]
@using Drafts.Services
@inject AuthService Auth
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Nav
@inject DraftsService GameService

<PageTitle>Player</PageTitle>

<h3>Player</h3>

<p>You are logged in as <b>@(HttpContextAccessor.HttpContext?.User?.Identity?.Name)</b>.</p>

<div style="max-width:360px;margin-top:12px;">
    <button style="width:100%;padding:10px 12px;" onclick="location.href='/drafts'">Start a new game</button>
</div>

<h4>Join Game</h4>

<div style="max-width:360px">
    <div style="display:flex;flex-direction:column;gap:8px">
        <select @bind="_selectedGameId">
            <option value="">Select a game…</option>
            @foreach (var g in _joinableGames)
            {
                <option value="@g.Id">@FormatGameOption(g)</option>
            }
        </select>
        <button @onclick="OnJoinGame" disabled="@string.IsNullOrWhiteSpace(_selectedGameId)">Join game</button>
        @if (!string.IsNullOrWhiteSpace(_joinMessage))
        {
            <div>@_joinMessage</div>
        }
    </div>
</div>

@code {
    private string _selectedGameId = "";
    private string _joinMessage = "";

    private Dictionary<int, string> _userNames = new();

    private List<DraftsService.GameListItem> _joinableGames = new();

    protected override void OnInitialized()
    {
        _ = InvokeAsync(async () =>
        {
            var users = await Auth.ListUsersAsync();
            _userNames = users.ToDictionary(x => x.Id, x => x.Name ?? "");
            await InvokeAsync(StateHasChanged);
        });
        RefreshGames();
        GameService.GameUpdated += OnGameUpdated;
    }

    public void Dispose()
    {
        GameService.GameUpdated -= OnGameUpdated;
    }

    private int? GetCurrentUserId()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var raw = user?.FindFirst("uid")?.Value;
        return int.TryParse(raw, out var id) ? id : null;
    }

    private void OnJoinGame()
    {
        _joinMessage = "";

        var gameId = (_selectedGameId ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(gameId))
        {
            _joinMessage = "Select a game.";
            return;
        }

        Nav.NavigateTo($"/drafts?gameId={gameId}");
    }

    private void OnGameUpdated(string _)
    {
        RefreshGames();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshGames()
    {
        var uid = GetCurrentUserId();
        var games = GameService.ListGames();

        _joinableGames = games
            .Where(g => !g.HadSecondPlayerConnected)
            .Where(g => !(g.Player1Connected && g.Player2Connected))
            .Where(g => !(uid.HasValue && (g.Player1UserId == uid.Value || g.Player2UserId == uid.Value)))
            .OrderByDescending(g => g.CreatedUtc)
            .ToList();

        if (!string.IsNullOrWhiteSpace(_selectedGameId) && !_joinableGames.Any(x => x.Id == _selectedGameId))
        {
            _selectedGameId = "";
        }
    }

    private string FormatGameOption(DraftsService.GameListItem g)
    {
        var createdLocal = g.CreatedUtc.ToLocalTime();
        var connectedText = g.HadSecondPlayerConnected ? "(connected)" : "(not connected)";
        _userNames.TryGetValue(g.CreatedByUserId, out var name);
        name ??= "";
        return $"{name}  {g.Id} — {createdLocal:yyyy-MM-dd HH:mm:ss} {connectedText}";
    }
}
