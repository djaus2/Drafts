    private async void OnGameUpdated(string _)
    {
        await RefreshGames();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshGames()
    {
        var uid = GetCurrentUserId();
        var games = GameService.ListGames();

        // Get user's groups for filtering
        var userGroupIds = new List<int>();
        if (uid.HasValue && _userGroups?.Any() == true)
        {
            userGroupIds = _userGroups.Select(g => g.Id).ToList();
        }

        _joinableGames = games
            .Where(g => !g.HadSecondPlayerConnected)
            .Where(g => !(g.Player1Connected && g.Player2Connected))
            .Where(g => !(uid.HasValue && (g.Player1UserId == uid.Value || g.Player2UserId == uid.Value)))
            // Group filtering: show public games (no GroupId) or games where user is a member of the group
            .Where(g => !g.GroupId.HasValue || userGroupIds.Contains(g.GroupId.Value))
            .OrderByDescending(g => g.CreatedUtc)
            .ToList();

        var joinableGroupGames = _joinableGames
            .Where(g => g.GroupId.HasValue && userGroupIds.Contains(g.GroupId.Value))
            .ToList();

        if (!string.IsNullOrWhiteSpace(_selectedGameId) && !_joinableGames.Any(x => x.Id == _selectedGameId))
        {
            _selectedGameId = "";
        }

        if (string.IsNullOrWhiteSpace(_selectedGameId) && joinableGroupGames.Count == 1)
        {
            _selectedGameId = joinableGroupGames[0].Id;
        }
        else if (string.IsNullOrWhiteSpace(_selectedGameId) && _joinableGames.Count == 1)
        {
            _selectedGameId = _joinableGames[0].Id;
        }
    }

    private string FormatGameOption(DraftsService.GameListItem g)
    {
        var createdLocal = g.CreatedUtc.ToLocalTime();
        var connectedText = g.HadSecondPlayerConnected ? "(connected)" : "(not connected)";
        _userNames.TryGetValue(g.CreatedByUserId, out var name);
        name ??= "";
        
        // Add group information
        var groupInfo = "";
        if (g.GroupId.HasValue)
        {
            var group = _userGroups?.FirstOrDefault(ug => ug.Id == g.GroupId.Value);
            groupInfo = group != null ? $" [{group.Name}]" : " [Group]";
        }
        else
        {
            groupInfo = " [Public]";
        }
        
        return $"{name}  {g.Id} — {createdLocal:yyyy-MM-dd HH:mm:ss} {connectedText}{groupInfo}";
    }
