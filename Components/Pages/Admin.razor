    private async Task LoadLogs()
    {
        try
        {
            // Parse search parameters
            LogType? logType = null;
            if (!string.IsNullOrWhiteSpace(_selectedLogType))
            {
                if (int.TryParse(_selectedLogType, out var typeValue))
                {
                    logType = (LogType)typeValue;
                }
            }

            int? gameId = null;
            if (!string.IsNullOrWhiteSpace(_searchGameId))
            {
                if (int.TryParse(_searchGameId, System.Globalization.NumberStyles.HexNumber, null, out var gameIdValue))
                {
                    gameId = gameIdValue;
                }
            }

            // Use the new search method
            _logs = await GameLog.SearchLogsAsync(
                playerId: _searchPlayerId,
                gameId: gameId,
                groupId: _searchGroupId,
                logType: logType,
                count: _logCount
            );
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading logs: {ex.Message}");
            _logs = new List<Draughts.Data.GameLog>();
        }
    }

    private void ClearSearch()
    {
        _selectedLogType = "";
        _searchPlayerId = null;
        _searchGameId = "";
        _searchGroupId = null;
        _ = LoadLogs();
    }

