@page "/admin"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@implements IDisposable
@using Draughts.Services
@using Draughts.Data
@inject AuthService Auth
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject DraughtsService GameService
@inject SettingsService Settings
@inject UsableMsVoiceService UsableMsVoices
@inject GameLogService GameLog

<PageTitleHeading Title="Admin" HeadingLevel="2" />

<p>You are logged in as <b>@(HttpContextAccessor.HttpContext?.User?.Identity?.Name)</b>.</p>

<div style="display:flex;flex-direction:column;gap:6px">
    <a href="/admin/users">Manage players</a>
    <a href="/admin/groups">Manage groups</a>
    <a href="/player">Reset your password</a>
    <button type="button" @onclick="OpenLogViewer" style="text-align:left;padding:0;border:none;background:none;color:blue;text-decoration:underline;cursor:pointer;">View game logs</button>
    <form method="get" action="/api/admin/download-database" style="display:inline;">
    <button type="submit" style="text-align:left;padding:0;border:none;background:none;color:blue;text-decoration:underline;cursor:pointer;">Download database backup</button>
    </form>
    <button type="button" @onclick="ResetDatabase" style="text-align:left;padding:0;border:none;background:none;color:red;text-decoration:underline;cursor:pointer;">⚠️ Reset database (delete all data)</button>
</div>

<div style="max-width:360px;margin-top:12px;">
    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px;">
        <div>Game Initiator is:</div>
        <label style="display:flex;align-items:center;gap:6px;">
            <input type="radio" name="creatorColor" value="1" checked="@(_creatorPlayerNumber == 1)" @onchange="(() => _creatorPlayerNumber = 1)" />
            Black
        </label>
        <label style="display:flex;align-items:center;gap:6px;">
            <input type="radio" name="creatorColor" value="2" checked="@(_creatorPlayerNumber == 2)" @onchange="(() => _creatorPlayerNumber = 2)" />
            White
        </label>
    </div>
    <button style="width:100%;padding:10px 12px;" @onclick="StartNewGame">Start a new game</button>
</div>

<h4 class="rainbow-heading rainbow-heading--sm" style="margin-top:18px;">Voices</h4>

<div style="max-width:520px">
    <div style="display:flex;flex-direction:column;gap:8px">
        <button @onclick="LoadAdminVoicesFromUserGesture" disabled="@_checkingChromeVoices">Load voices</button>
        <select @key="_adminVoicesLoaded" value="@_adminSelectedLanguage" @onchange="OnAdminLanguageChanged" disabled="@(!_adminVoicesLoaded)">
            <option value="">All languages</option>
            @foreach (var l in _adminLanguages)
            {
                <option @key="l" value="@l">@FormatLanguageLabel(l)</option>
            }
        </select>
        <select @key="_adminSelectedLanguage" value="@_adminSelectedRegion" @onchange="OnAdminRegionChanged" disabled="@(!_adminRegions.Any())">
            <option value="">All countries</option>
            @foreach (var r in _adminRegions)
            {
                <option @key="r" value="@r">@FormatRegionLabel(_adminSelectedLanguage, r)</option>
            }
        </select>
        <select @key="@($"{_adminSelectedLanguage}|{_adminSelectedRegion}")" value="@_adminFocusedVoiceKey" @onchange="OnAdminFocusedVoiceChanged" disabled="@(!_adminFilteredVoices.Any())">
            <option value="">Select a voice</option>
            @foreach (var v in _adminFilteredVoices)
            {
                <option @key="v.Key" value="@v.Key">@v.Label</option>
            }
        </select>
        <div style="font-size:12px;opacity:0.85;">Loaded voices: @_adminAllVoices.Count. Allowed for players: @_adminSelectedVoiceTokens.Count.</div>
        <div style="font-size:12px;opacity:0.85;">Raw browser voices: @_adminRawVoiceCount.@(_checkingChromeVoices ? " Loading…" : "")</div>
        @if (_adminFilteredVoices.Any())
        {
            <div style="display:flex;flex-direction:column;gap:6px;max-height:260px;overflow:auto;border:1px solid #ddd;padding:8px;">
                @foreach (var voice in _adminFilteredVoices)
                {
                    <label style="display:flex;align-items:flex-start;gap:8px;">
                        <input type="checkbox" checked="@_adminSelectedVoiceTokens.Contains(voice.Token)" @onchange="@(e => OnAdminVoiceCheckedChanged(voice, e))" />
                        <span>@voice.Label</span>
                    </label>
                }
            </div>
        }
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button @onclick="SelectAllFilteredAdminVoices" disabled="@(!_adminFilteredVoices.Any())">Select filtered</button>
            <button @onclick="ClearAllFilteredAdminVoices" disabled="@(!_adminFilteredVoices.Any())">Clear filtered</button>
            <button @onclick="ToggleShowSelectedAdminVoices" disabled="@(!_adminSelectedVoiceTokens.Any())">@(_adminShowSelectedVoicesOnly ? "Show all voices" : "Show selected voices")</button>
            <button @onclick="SaveAllowedVoices" disabled="@(!_adminAllVoices.Any())">Save allowed voices</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(_voiceCatalogMessage))
        {
            <div>@_voiceCatalogMessage</div>
        }
    </div>
</div>

<h4 class="rainbow-heading rainbow-heading--sm" style="margin-top:18px;">Settings</h4>

<div style="max-width:360px">
    <div style="display:flex;flex-direction:column;gap:8px">
        <label style="display:flex;flex-direction:column;gap:4px">
            Max timeout (mins)
            <input @bind="_maxMoveTimeoutMins" inputmode="numeric" />
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Max game time (mins)
            <input @bind="_maxGameTimeMins" inputmode="numeric" />
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Max game start wait time (mins)
            <input @bind="_maxGameStartWaitTimeMins" inputmode="numeric" />
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Max login hours
            <input @bind="_maxLoginHrs" inputmode="numeric" />
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Reaper period (seconds)
            <input @bind="_reaperPeriodSeconds" inputmode="numeric" />
        </label>
        <label style="display:flex;align-items:center;gap:8px">
            <input type="checkbox" @bind="_entrapmentMode" />
            Entrapment mode
            <br />
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Multi-jump grace period (seconds)
            <input type="number" min="0" step="0.5" @bind="_multiJumpGraceSeconds" inputmode="decimal" />
            <i><b>Nb:</b> 0.5s steps; rules default is 1.5s</i><br />
        </label>
        <label style="display:flex;align-items:center;gap:8px">
            <input type="checkbox" @bind="_gameInitiatorGoesFirst" />
            Game Initiator goes first
            <br />
        </label>
        <label style="display:flex;align-items:center;gap:8px">
            <input type="checkbox" @bind="_allowPlayerPinChange" />
            Allow players to change their PIN
            <br />
            <i><b>Note:</b> When disabled, only Admins can change PINs</i>
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Last move highlight color
            <select @bind="_lastMoveHighlightColor">
                @foreach (var item in HighlightColorOptions)
                {
                    <option value="@item.Value">@item.Label</option>
                }
            </select>
        </label>
        <button @onclick="SaveSettings">Save</button>
        @if (!string.IsNullOrWhiteSpace(_settingsMessage))
        {
            <div>@_settingsMessage</div>
        }
    </div>
</div>

<h4 class="rainbow-heading rainbow-heading--sm" style="margin-top:18px;">Games</h4>

@if (_games is null)
{
    <p>Loading…</p>
}
else if (_games.Count == 0)
{
    <p>No active games.</p>
}
else
{
    <table style="border-collapse:collapse;max-width:900px;">
        <thead>
            <tr>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">Id</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">Started</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">Runtime</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">Idle</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">P1</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">P2</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var g in _games.OrderByDescending(x => x.StartTimeUtc))
            {
                <tr>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@GetUserName(g.CreatedByUserId)  @g.Id</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@g.StartTimeUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@FormatAge(DateTime.UtcNow - g.StartTimeUtc)</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@FormatAge(DateTime.UtcNow - g.LastTimeUtc)</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@FormatPlayer(g.Player1UserId, g.Player1Connected)</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@FormatPlayer(g.Player2UserId, g.Player2Connected)</td>
                </tr>
            }
        </tbody>
    </table>
}

 <h4 class="rainbow-heading rainbow-heading--sm" style="margin-top:18px;">Change Admin PIN</h4>

<div style="max-width:360px">
    <div style="display:flex;flex-direction:column;gap:8px">
        To change Admin Pin: <a href="/player">Reset your password</a> page and follow instructions there.
@*         <input @bind="_currentPin" placeholder="Current PIN" inputmode="numeric" maxlength="6" />
        <input @bind="_newPin" placeholder="New PIN (4-6 digits)" inputmode="numeric" maxlength="6" />
        <button @onclick="OnChangePin">Change PIN</button>
        @if (!string.IsNullOrWhiteSpace(_pinMessage))
        {
            <div>@_pinMessage</div>
        } *@
    </div>
</div> 

<LobbyChat />

@if (_showLogViewer)
{
    <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:1000;" @onclick="CloseLogViewer">
        <div style="background:white;padding:20px;border-radius:8px;max-width:90%;max-height:90%;overflow:auto;box-shadow:0 4px 6px rgba(0,0,0,0.1);" @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                <h3 style="margin:0;">Game Activity Logs</h3>
                <button @onclick="CloseLogViewer" style="padding:4px 12px;">Close</button>
            </div>
            
            <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;">
                <label style="display:flex;align-items:center;gap:4px;">
                    Show last:
                    <select @bind="_logCount" @bind:after="LoadLogs">
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                        <option value="500">500</option>
                    </select>
                    entries
                </label>
                <label style="display:flex;align-items:center;gap:4px;">
                    Filter by type:
                    <select @bind="_selectedLogType" @bind:after="LoadLogs">
                        <option value="">All</option>
                        <option value="1">Player Login</option>
                        <option value="2">Player Logout</option>
                        <option value="3">Player PIN Change</option>
                        <option value="10">Game Created</option>
                        <option value="11">Game Started</option>
                        <option value="12">Game Ended</option>
                        <option value="13">Game Joined</option>
                        <option value="20">Move Made</option>
                        <option value="21">Turn Timeout</option>
                        <option value="22">Game Timeout</option>
                        <option value="30">System Startup</option>
                        <option value="32">Error</option>
                        <option value="33">Warning</option>
                        <option value="40">Admin Action</option>
                        <option value="41">User Management</option>
                        <option value="42">Settings Changed</option>
                    </select>
                </label>
                <label style="display:flex;align-items:center;gap:4px;">
                    Player ID:
                    <input type="number" @bind="_searchPlayerId" @bind:after="LoadLogs" style="width:80px;" placeholder="Any" />
                </label>
                <label style="display:flex;align-items:center;gap:4px;">
                    Game ID:
                    <input type="text" @bind="_searchGameId" @bind:after="LoadLogs" style="width:100px;" placeholder="Any" />
                </label>
                <label style="display:flex;align-items:center;gap:4px;">
                    Group ID:
                    <input type="number" @bind="_searchGroupId" @bind:after="LoadLogs" style="width:80px;" placeholder="Any" />
                </label>
                <button @onclick="LoadLogs">Refresh</button>
                <button @onclick="ClearSearch">Clear</button>
            </div>
            
            @if (_logs == null)
            {
                <p>Loading logs...</p>
            }
            else if (_logs.Count == 0)
            {
                <p>No log entries found.</p>
            }
            else
            {
                <div style="overflow:auto;max-height:60vh;">
                    <table style="border-collapse:collapse;width:100%;font-size:13px;">
                        <thead style="position:sticky;top:0;background:white;">
                            <tr style="border-bottom:2px solid #ccc;">
                                <th style="text-align:left;padding:8px;white-space:nowrap;">Timestamp</th>
                                <th style="text-align:left;padding:8px;white-space:nowrap;">Type</th>
                                <th style="text-align:left;padding:8px;white-space:nowrap;">Player</th>
                                <th style="text-align:left;padding:8px;white-space:nowrap;">Game</th>
                                <th style="text-align:left;padding:8px;white-space:nowrap;">Group</th>
                                <th style="text-align:left;padding:8px;">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in _logs)
                            {
                                <tr style="border-bottom:1px solid #eee;">
                                    <td style="padding:8px;white-space:nowrap;vertical-align:top;">@log.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td style="padding:8px;white-space:nowrap;vertical-align:top;">
                                        <span style="background:@GetLogTypeColor(log.LogType);color:white;padding:2px 6px;border-radius:3px;font-size:11px;">
                                            @log.LogType
                                        </span>
                                    </td>
                                    <td style="padding:8px;white-space:nowrap;vertical-align:top;">
                                        @if (log.PlayerId > 0)
                                        {
                                            @(_userNames.TryGetValue(log.PlayerId, out var playerName) ? playerName : $"Player {log.PlayerId}")
                                            if (log.OpponentPlayerId.HasValue)
                                            {
                                                <text> vs </text>
                                                @(_userNames.TryGetValue(log.OpponentPlayerId.Value, out var opponentName) ? opponentName : $"Player {log.OpponentPlayerId.Value}")
                                            }
                                        }
                                        else
                                        {
                                            <text>System</text>
                                        }
                                    </td>
                                    <td style="padding:8px;white-space:nowrap;vertical-align:top;">
                                        @if (log.GameId.HasValue)
                                        {
                                            <text>@log.GameId.Value</text>
                                        }
                                        else
                                        {
                                            <text>-</text>
                                        }
                                    </td>
                                    <td style="padding:8px;white-space:nowrap;vertical-align:top;">
                                        @GetGroupName(log.GroupId)
                                    </td>
                                    <td style="padding:8px;vertical-align:top;">@log.Details</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div style="margin-top:12px;font-size:12px;color:#666;">
                    Showing @_logs.Count log entries
                </div>
            }
        </div>
    </div>
}

@code {
    private int _creatorPlayerNumber = 1;
    // private string _currentPin = "";
    // private string _newPin = "";
    // private string _pinMessage = "";

    private Dictionary<int, string> _userNames = new();
    private List<Draughts.Data.Group> _userGroups = new();
    
    // Log viewer state
    private bool _showLogViewer = false;
    private List<Draughts.Data.GameLog>? _logs = null;
    private int _logCount = 100;
    private string _selectedLogType = "";
    private int? _searchPlayerId = null;
    private string _searchGameId = "";
    private int? _searchGroupId = null;

    // Timeouts, after which the game is cancelled //////////////////////////
    private int _maxMoveTimeoutMins = 5;         //Time a player gets to move after other player moves
    private int _maxGameTimeMins = 30;           // Max time a game can run after it starts
    private int _maxGameStartWaitTimeMins = 30;  // Max time an initiated (waiting) game can wait to start
    private int _reaperPeriodSeconds = 30;       // Time between game garabage collections
    private int _maxLoginHrs = 4;                // Max time a login session is valid before requiring re-login so can't hog a game indefinitely
    /////////////////////////////////////////////////////////////////////////
    private string _lastMoveHighlightColor = "rgba(255,0,0,0.85)";
    private bool _entrapmentMode = true;
    private double _multiJumpGraceSeconds = 1.5;
    private bool _gameInitiatorGoesFirst = true;
    private bool _allowPlayerPinChange = true;
    private string _settingsMessage = "";
    private string _voiceCatalogMessage = "";
    private bool _checkingChromeVoices;
    private List<Draughts.Data.UsableMsVoice> _chromeUsableVoices = new();
    private List<VoiceOptionInternal> _adminAllVoices = new();
    private List<VoiceOptionInternal> _adminFilteredVoices = new();
    private List<string> _adminLanguages = new();
    private List<string> _adminRegions = new();
    private HashSet<string> _adminSelectedVoiceTokens = new(StringComparer.OrdinalIgnoreCase);
    private string _adminSelectedLanguage = "";
    private string _adminSelectedRegion = "";
    private string _adminFocusedVoiceKey = "";
    private bool _adminShowSelectedVoicesOnly;
    private bool _adminVoicesLoaded;
    private int _adminRawVoiceCount;
    private bool _adminHasSpeechSynthesis;
    private bool _adminHasSpeechSynthesisUtterance;
    private int _adminBrowserVoiceCount;

    private sealed class JsVoiceInfo
    {
        public string? voiceURI { get; set; }
        public string? name { get; set; }
        public string? lang { get; set; }
    }

    private sealed class VoiceDiagnostics
    {
        public bool hasSpeechSynthesis { get; set; }
        public bool hasUtterance { get; set; }
        public int voiceCount { get; set; }
    }

    private sealed class VoiceOptionInternal
    {
        public string Key { get; set; } = "";
        public string Label { get; set; } = "";
        public string Lang { get; set; } = "";
        public string Token { get; set; } = "";
        public string VoiceName { get; set; } = "";
        public string VoiceUri { get; set; } = "";
    }

    private sealed record ColorOption(string Label, string Value);

    private IReadOnlyList<ColorOption> HighlightColorOptions
    {
        get
        {
            var list = new List<ColorOption>
            {
                new("Red (default)", "rgba(255,0,0,0.85)"),
                new("Orange", "rgba(255,140,0,0.85)"),
                new("Yellow", "rgba(255,215,0,0.85)"),
                new("Green", "rgba(0,200,83,0.85)"),
                new("Cyan", "rgba(0,188,212,0.85)"),
                new("Blue", "rgba(41,121,255,0.85)"),
                new("Purple", "rgba(213,0,249,0.85)"),
                new("Pink", "rgba(255,64,129,0.85)"),
                new("White", "rgba(255,255,255,0.85)"),
            };

            if (!list.Any(x => string.Equals(x.Value, _lastMoveHighlightColor, StringComparison.OrdinalIgnoreCase)))
            {
                list.Insert(0, new ColorOption($"Custom ({_lastMoveHighlightColor})", _lastMoveHighlightColor));
            }

            return list;
        }
    }

    private List<DraughtsService.GameListItem>? _games;

    protected override async Task OnInitializedAsync()
    {
        var users = await Auth.ListUsersAsync();
        _userNames = users.ToDictionary(x => x.Id, x => x.Name ?? "");
        
        // Load all groups for group name resolution in logs
        _userGroups = await Auth.ListGroupsAsync();
        
        _maxMoveTimeoutMins = await Settings.GetMaxMoveTimeoutMinsAsync();
        _maxGameTimeMins = await Settings.GetMaxGameTimeMinsAsync();
        _maxGameStartWaitTimeMins = await Settings.GetMaxGameStartWaitTimeMinsAsync();
        _maxLoginHrs = await Settings.GetMaxLoginHrsAsync();
        _reaperPeriodSeconds = await Settings.GetReaperPeriodSecondsAsync();
        _lastMoveHighlightColor = await Settings.GetLastMoveHighlightColorAsync();
        _entrapmentMode = await Settings.GetEntrapmentModeAsync();
        _multiJumpGraceSeconds = await Settings.GetMultiJumpGraceSecondsAsync();
        _gameInitiatorGoesFirst = await Settings.GetGameInitiatorGoesFirstAsync();
        _allowPlayerPinChange = await Settings.GetAllowPlayerPinChangeAsync();
        _chromeUsableVoices = UsableMsVoices.GetVoices("chrome").ToList();
        _adminSelectedVoiceTokens = _chromeUsableVoices
            .Select(x => x.Token)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        RefreshGames();
        GameService.GameUpdated += OnGameUpdated;
    }

    private string GetUserName(int userId)
    {
        if (userId <= 0) return "";
        return _userNames.TryGetValue(userId, out var name) ? name : "";
    }

    public void Dispose()
    {
        GameService.GameUpdated -= OnGameUpdated;
    }

    private void OnGameUpdated(string _)
    {
        RefreshGames();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshGames()
    {
        _games = GameService.ListGames();
    }

    private async Task SaveSettings()
    {
        _settingsMessage = "";
        var ok1 = await Settings.UpdateMaxMoveTimeoutMinsAsync(_maxMoveTimeoutMins);
        var ok2 = await Settings.UpdateMaxGameTimeMinsAsync(_maxGameTimeMins);
        var ok3 = await Settings.UpdateMaxGameStartWaitTimeMinsAsync(_maxGameStartWaitTimeMins);
        var ok4 = await Settings.UpdateMaxLoginHrsAsync(_maxLoginHrs);
        var ok5 = await Settings.UpdateReaperPeriodSecondsAsync(_reaperPeriodSeconds);
        var ok6 = await Settings.UpdateLastMoveHighlightColorAsync(_lastMoveHighlightColor);
        var ok7 = await Settings.UpdateEntrapmentModeAsync(_entrapmentMode);
        var ok8 = await Settings.UpdateMultiJumpGraceSecondsAsync(_multiJumpGraceSeconds);
        var ok9 = await Settings.UpdateGameInitiatorGoesFirstAsync(_gameInitiatorGoesFirst);
        var ok10 = await Settings.UpdateAllowPlayerPinChangeAsync(_allowPlayerPinChange);
        _settingsMessage = (ok1 && ok2 && ok3 && ok4 && ok5 && ok6 && ok7 && ok8 && ok9 && ok10) ? "Saved." : "Invalid value.";
    }

    private async Task LoadAdminVoicesFromUserGesture()
    {
        _voiceCatalogMessage = "";
        _checkingChromeVoices = true;

        try
        {
            try
            {
                await JS.InvokeAsync<bool>("DraughtsVoice.warmupVoices");
            }
            catch
            {
            }

            List<JsVoiceInfo>? raw = null;
            VoiceDiagnostics? diagnostics = null;

            try
            {
                using var diagCts = new CancellationTokenSource(TimeSpan.FromSeconds(2));
                diagnostics = await JS.InvokeAsync<VoiceDiagnostics>("DraughtsVoice.getVoiceDiagnostics", diagCts.Token);
            }
            catch
            {
            }

            try
            {
                using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(16));
                raw = await JS.InvokeAsync<List<JsVoiceInfo>>("DraughtsVoice.getVoicesAsync", cts.Token);
            }
            catch (OperationCanceledException)
            {
                try
                {
                    await JS.InvokeAsync<bool>("DraughtsVoice.refreshVoices");
                }
                catch
                {
                }

                using var retryCts = new CancellationTokenSource(TimeSpan.FromSeconds(16));
                raw = await JS.InvokeAsync<List<JsVoiceInfo>>("DraughtsVoice.getVoicesAsync", retryCts.Token);
            }

            _adminHasSpeechSynthesis = diagnostics?.hasSpeechSynthesis ?? false;
            _adminHasSpeechSynthesisUtterance = diagnostics?.hasUtterance ?? false;
            _adminBrowserVoiceCount = diagnostics?.voiceCount ?? -1;
            _adminRawVoiceCount = raw?.Count ?? 0;

            _adminAllVoices = (raw ?? new List<JsVoiceInfo>())
                .Select(v =>
                {
                    var voiceUri = (v?.voiceURI ?? string.Empty).Trim();
                    var voiceName = (v?.name ?? string.Empty).Trim();
                    var voiceLang = (v?.lang ?? string.Empty).Trim();
                    var key = !string.IsNullOrWhiteSpace(voiceUri)
                        ? $"uri:{voiceUri}"
                        : $"name:{voiceName}|lang:{voiceLang}";
                    var label = string.IsNullOrWhiteSpace(voiceLang)
                        ? voiceName
                        : $"{voiceName} ({voiceLang})";
                    var token = VoiceCatalog.NormalizeToken(voiceName, voiceLang);

                    return new VoiceOptionInternal
                    {
                        Key = key,
                        Label = label,
                        Lang = voiceLang,
                        Token = token,
                        VoiceName = voiceName,
                        VoiceUri = voiceUri
                    };
                })
                .Where(x => !string.IsNullOrWhiteSpace(x.Label))
                .Where(x => !string.IsNullOrWhiteSpace(x.Token))
                .DistinctBy(x => x.Key)
                .OrderBy(x => x.Label)
                .ToList();

            _adminVoicesLoaded = _adminAllVoices.Count > 0;
            ApplyAdminVoiceFilters();
            _voiceCatalogMessage = _adminAllVoices.Count == 0
                ? $"No voices found in this browser instance. Raw voices: {_adminRawVoiceCount}. speechSynthesis: {_adminHasSpeechSynthesis}. utterance: {_adminHasSpeechSynthesisUtterance}. browser count: {_adminBrowserVoiceCount}."
                : $"Loaded {_adminAllVoices.Count} voices from this browser. Raw voices: {_adminRawVoiceCount}. speechSynthesis: {_adminHasSpeechSynthesis}. utterance: {_adminHasSpeechSynthesisUtterance}. browser count: {_adminBrowserVoiceCount}.";
        }
        catch (OperationCanceledException)
        {
            _voiceCatalogMessage = $"Voice loading timed out. Tap Load voices again. speechSynthesis: {_adminHasSpeechSynthesis}. utterance: {_adminHasSpeechSynthesisUtterance}. browser count: {_adminBrowserVoiceCount}.";
        }
        catch (Exception ex)
        {
            var msg = ex.Message ?? string.Empty;
            if (msg.Length > 160) msg = msg.Substring(0, 160);
            _voiceCatalogMessage = $"Voice load failed: {ex.GetType().Name}: {msg}";
        }
        finally
        {
            _checkingChromeVoices = false;
        }
    }

    private async Task OnAdminLanguageChanged(ChangeEventArgs e)
    {
        _adminSelectedLanguage = (e?.Value?.ToString() ?? string.Empty).Trim();
        _adminSelectedRegion = "";
        _adminFocusedVoiceKey = "";
        ApplyAdminVoiceFilters();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAdminRegionChanged(ChangeEventArgs e)
    {
        _adminSelectedRegion = (e?.Value?.ToString() ?? string.Empty).Trim();
        _adminFocusedVoiceKey = "";
        ApplyAdminVoiceFilters();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAdminFocusedVoiceChanged(ChangeEventArgs e)
    {
        _adminFocusedVoiceKey = (e?.Value?.ToString() ?? string.Empty).Trim();
        await InvokeAsync(StateHasChanged);
    }

    private Task OnAdminVoiceCheckedChanged(VoiceOptionInternal voice, ChangeEventArgs e)
    {
        var isChecked = false;
        if (e?.Value is bool b)
        {
            isChecked = b;
        }
        else
        {
            _ = bool.TryParse(e?.Value?.ToString(), out isChecked);
        }

        if (isChecked)
        {
            _adminSelectedVoiceTokens.Add(voice.Token);
        }
        else
        {
            _adminSelectedVoiceTokens.Remove(voice.Token);
        }

        return InvokeAsync(StateHasChanged);
    }

    private Task SelectAllFilteredAdminVoices()
    {
        foreach (var voice in _adminFilteredVoices)
        {
            _adminSelectedVoiceTokens.Add(voice.Token);
        }

        return InvokeAsync(StateHasChanged);
    }

    private Task ClearAllFilteredAdminVoices()
    {
        foreach (var voice in _adminFilteredVoices)
        {
            _adminSelectedVoiceTokens.Remove(voice.Token);
        }

        ApplyAdminVoiceFilters();
        return InvokeAsync(StateHasChanged);
    }

    private Task ToggleShowSelectedAdminVoices()
    {
        _adminShowSelectedVoicesOnly = !_adminShowSelectedVoicesOnly;
        _adminFocusedVoiceKey = "";
        ApplyAdminVoiceFilters();
        return InvokeAsync(StateHasChanged);
    }

    private async Task SaveAllowedVoices()
    {
        _voiceCatalogMessage = "";

        try
        {
            var items = _adminAllVoices
                .Where(x => _adminSelectedVoiceTokens.Contains(x.Token))
                .Select(x => (x.Token, x.VoiceName, (string?)x.Lang, string.IsNullOrWhiteSpace(x.VoiceUri) ? null : x.VoiceUri))
                .ToList();

            var saved = await UsableMsVoices.ReplaceVoicesAsync("chrome", items);
            _chromeUsableVoices = UsableMsVoices.GetVoices("chrome").ToList();
            _adminSelectedVoiceTokens = _chromeUsableVoices
                .Select(x => x.Token)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            _voiceCatalogMessage = $"Saved {saved} allowed Chrome voices.";
        }
        catch (Exception ex)
        {
            var msg = ex.Message ?? string.Empty;
            if (msg.Length > 160) msg = msg.Substring(0, 160);
            _voiceCatalogMessage = $"Saving allowed voices failed: {ex.GetType().Name}: {msg}";
        }
    }

    private void ApplyAdminVoiceFilters()
    {
        static HashSet<string> KnownLanguages() => new(StringComparer.OrdinalIgnoreCase)
        {
            "en","fr","es","de","it","pt","nl","sv","da","no","fi"
        };

        static HashSet<string> KnownRegionsForLang(string? language)
        {
            if (!string.Equals(language, "en", StringComparison.OrdinalIgnoreCase))
            {
                return new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            }

            return new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            {
                "US","GB","AU","CA","NZ","IE","IN","ZA"
            };
        }

        static string GetLanguage(string? lang)
        {
            if (string.IsNullOrWhiteSpace(lang)) return "";
            lang = lang.Trim();
            var sep = lang.IndexOf('-');
            if (sep < 0) sep = lang.IndexOf('_');
            if (sep < 0) return lang.ToLowerInvariant();
            if (sep <= 0) return "";
            return lang.Substring(0, sep).Trim().ToLowerInvariant();
        }

        static string GetRegion(string? lang)
        {
            if (string.IsNullOrWhiteSpace(lang)) return "";
            lang = lang.Trim();
            var sep = lang.IndexOf('-');
            if (sep < 0) sep = lang.IndexOf('_');
            if (sep < 0) return "";
            if (sep + 1 >= lang.Length) return "";
            return lang.Substring(sep + 1).Trim().ToUpperInvariant();
        }

        _adminLanguages = _adminAllVoices
            .Select(v => GetLanguage(v.Lang))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => KnownLanguages().Contains(x) ? 0 : 1)
            .ThenBy(x => FormatLanguageLabel(x))
            .ThenBy(x => x)
            .ToList();

        if (!string.IsNullOrWhiteSpace(_adminSelectedLanguage)
            && !_adminLanguages.Contains(_adminSelectedLanguage, StringComparer.OrdinalIgnoreCase))
        {
            _adminSelectedLanguage = "";
            _adminSelectedRegion = "";
        }

        var langFiltered = string.IsNullOrWhiteSpace(_adminSelectedLanguage)
            ? _adminAllVoices
            : _adminAllVoices.Where(v => string.Equals(GetLanguage(v.Lang), _adminSelectedLanguage, StringComparison.OrdinalIgnoreCase)).ToList();

        _adminRegions = langFiltered
            .Select(v => GetRegion(v.Lang))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => KnownRegionsForLang(_adminSelectedLanguage).Contains(x) ? 0 : 1)
            .ThenBy(x => FormatRegionLabel(_adminSelectedLanguage, x))
            .ThenBy(x => x)
            .ToList();

        if (!string.IsNullOrWhiteSpace(_adminSelectedRegion)
            && !_adminRegions.Contains(_adminSelectedRegion, StringComparer.OrdinalIgnoreCase))
        {
            _adminSelectedRegion = "";
        }

        var regionFiltered = string.IsNullOrWhiteSpace(_adminSelectedRegion)
            ? langFiltered
            : langFiltered.Where(v => string.Equals(GetRegion(v.Lang), _adminSelectedRegion, StringComparison.OrdinalIgnoreCase)).ToList();

        _adminFilteredVoices = (_adminShowSelectedVoicesOnly
                ? regionFiltered.Where(v => _adminSelectedVoiceTokens.Contains(v.Token)).ToList()
                : regionFiltered)
            .OrderBy(v => v.Label)
            .ToList();

        if (!string.IsNullOrWhiteSpace(_adminFocusedVoiceKey)
            && !_adminFilteredVoices.Any(v => v.Key == _adminFocusedVoiceKey))
        {
            _adminFocusedVoiceKey = "";
        }
    }

    private static string FormatLanguageLabel(string language)
    {
        language = (language ?? string.Empty).Trim().ToLowerInvariant();
        return language switch
        {
            "en" => "English (en)",
            "fr" => "French (fr)",
            "es" => "Spanish (es)",
            "de" => "German (de)",
            "it" => "Italian (it)",
            "pt" => "Portuguese (pt)",
            "nl" => "Dutch (nl)",
            "sv" => "Swedish (sv)",
            "da" => "Danish (da)",
            "no" => "Norwegian (no)",
            "fi" => "Finnish (fi)",
            _ => language
        };
    }

    private static string FormatRegionLabel(string? language, string region)
    {
        var lang = (language ?? string.Empty).Trim();
        region = (region ?? string.Empty).Trim().ToUpperInvariant();
        if (string.Equals(lang, "en", StringComparison.OrdinalIgnoreCase))
        {
            return region switch
            {
                "US" => "United States (en-US)",
                "GB" => "United Kingdom (en-GB)",
                "AU" => "Australia (en-AU)",
                "CA" => "Canada (en-CA)",
                "NZ" => "New Zealand (en-NZ)",
                "IE" => "Ireland (en-IE)",
                "IN" => "India (en-IN)",
                "ZA" => "South Africa (en-ZA)",
                _ => region
            };
        }

        return string.IsNullOrWhiteSpace(lang)
            ? region
            : $"{region} ({lang}-{region})";
    }

    private static string FormatAge(TimeSpan ts)
    {
        if (ts < TimeSpan.Zero) ts = TimeSpan.Zero;

        if (ts.TotalHours >= 1)
        {
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        }
        return $"{ts.Minutes}m {ts.Seconds}s";
    }

    private static string FormatPlayer(int? userId, bool connected)
    {
        if (!connected) return "(open)";
        return userId.HasValue ? $"{userId.Value}" : "(connected)";
    }

