@page "/admin"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@implements IDisposable
@using Drafts.Services
@inject AuthService Auth
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Nav
@inject DraftsService GameService
@inject SettingsService Settings

<PageTitleHeading Title="Admin" HeadingLevel="2" />

<p>You are logged in as <b>@(HttpContextAccessor.HttpContext?.User?.Identity?.Name)</b>.</p>

<div style="display:flex;flex-direction:column;gap:6px">
    <a href="/admin/users">Manage players</a>
    <a href="/player">Reset your password</a>
</div>

<div style="max-width:360px;margin-top:12px;">
    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px;">
        <div>Admin is</div>
        <label style="display:flex;align-items:center;gap:6px;">
            <input type="radio" name="adminColor" value="1" checked="@(_creatorPlayerNumber == 1)" @onchange="(() => _creatorPlayerNumber = 1)" />
            Black
        </label>
        <label style="display:flex;align-items:center;gap:6px;">
            <input type="radio" name="adminColor" value="2" checked="@(_creatorPlayerNumber == 2)" @onchange="(() => _creatorPlayerNumber = 2)" />
            White
        </label>
    </div>
    <button style="width:100%;padding:10px 12px;" @onclick="StartNewGame">Start a new game</button>
</div>

<h4 class="rainbow-heading rainbow-heading--sm" style="margin-top:18px;">Settings</h4>

<div style="max-width:360px">
    <div style="display:flex;flex-direction:column;gap:8px">
        <label style="display:flex;flex-direction:column;gap:4px">
            Max timeout (mins)
            <input @bind="_maxTimeoutMins" inputmode="numeric" />
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Reaper period (seconds)
            <input @bind="_reaperPeriodSeconds" inputmode="numeric" />
        </label>
        <label style="display:flex;align-items:center;gap:8px">
            <input type="checkbox" @bind="_entrapmentMode" />
            Entrapment mode
            <br />
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Multi-jump grace period (seconds)
            <input type="number" min="0" step="0.5" @bind="_multiJumpGraceSeconds" inputmode="decimal" />
            <i><b>Nb:</b> 0.5s steps; rules default is 1.5s</i><br />
        </label>
        <label style="display:flex;flex-direction:column;gap:4px">
            Last move highlight color
            <select @bind="_lastMoveHighlightColor">
                @foreach (var item in HighlightColorOptions)
                {
                    <option value="@item.Value">@item.Label</option>
                }
            </select>
        </label>
        <button @onclick="SaveSettings">Save</button>
        @if (!string.IsNullOrWhiteSpace(_settingsMessage))
        {
            <div>@_settingsMessage</div>
        }
    </div>
</div>

<h4 class="rainbow-heading rainbow-heading--sm" style="margin-top:18px;">Games</h4>

@if (_games is null)
{
    <p>Loading…</p>
}
else if (_games.Count == 0)
{
    <p>No active games.</p>
}
else
{
    <table style="border-collapse:collapse;max-width:900px;">
        <thead>
            <tr>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">Id</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">Started</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">Runtime</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">Idle</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">P1</th>
                <th style="text-align:left;padding:4px 8px;border-bottom:1px solid #ccc;">P2</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var g in _games.OrderByDescending(x => x.StartTimeUtc))
            {
                <tr>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@GetUserName(g.CreatedByUserId)  @g.Id</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@g.StartTimeUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@FormatAge(DateTime.UtcNow - g.StartTimeUtc)</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@FormatAge(DateTime.UtcNow - g.LastTimeUtc)</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@FormatPlayer(g.Player1UserId, g.Player1Connected)</td>
                    <td style="padding:4px 8px;border-bottom:1px solid #eee;">@FormatPlayer(g.Player2UserId, g.Player2Connected)</td>
                </tr>
            }
        </tbody>
    </table>
}

<h4 class="rainbow-heading rainbow-heading--sm" style="margin-top:18px;">Change PIN</h4>

<div style="max-width:360px">
    <div style="display:flex;flex-direction:column;gap:8px">
        <input @bind="_currentPin" placeholder="Current PIN" inputmode="numeric" maxlength="4" />
        <input @bind="_newPin" placeholder="New PIN" inputmode="numeric" maxlength="4" />
        <button @onclick="OnChangePin">Change PIN</button>
        @if (!string.IsNullOrWhiteSpace(_pinMessage))
        {
            <div>@_pinMessage</div>
        }
    </div>
</div>

<LobbyChat />

@code {
    private int _creatorPlayerNumber = 1;
    private string _currentPin = "";
    private string _newPin = "";
    private string _pinMessage = "";

    private Dictionary<int, string> _userNames = new();

    private int _maxTimeoutMins = 30;
    private int _reaperPeriodSeconds = 30;
    private string _lastMoveHighlightColor = "rgba(255,0,0,0.85)";
    private bool _entrapmentMode = true;
    private double _multiJumpGraceSeconds = 1.5;
    private string _settingsMessage = "";

    private sealed record ColorOption(string Label, string Value);

    private IReadOnlyList<ColorOption> HighlightColorOptions
    {
        get
        {
            var list = new List<ColorOption>
            {
                new("Red (default)", "rgba(255,0,0,0.85)"),
                new("Orange", "rgba(255,140,0,0.85)"),
                new("Yellow", "rgba(255,215,0,0.85)"),
                new("Green", "rgba(0,200,83,0.85)"),
                new("Cyan", "rgba(0,188,212,0.85)"),
                new("Blue", "rgba(41,121,255,0.85)"),
                new("Purple", "rgba(213,0,249,0.85)"),
                new("Pink", "rgba(255,64,129,0.85)"),
                new("White", "rgba(255,255,255,0.85)"),
            };

            if (!list.Any(x => string.Equals(x.Value, _lastMoveHighlightColor, StringComparison.OrdinalIgnoreCase)))
            {
                list.Insert(0, new ColorOption($"Custom ({_lastMoveHighlightColor})", _lastMoveHighlightColor));
            }

            return list;
        }
    }

    private List<DraftsService.GameListItem>? _games;

    protected override async Task OnInitializedAsync()
    {
        var users = await Auth.ListUsersAsync();
        _userNames = users.ToDictionary(x => x.Id, x => x.Name ?? "");
        _maxTimeoutMins = await Settings.GetMaxTimeoutMinsAsync();
        _reaperPeriodSeconds = await Settings.GetReaperPeriodSecondsAsync();
        _lastMoveHighlightColor = await Settings.GetLastMoveHighlightColorAsync();
        _entrapmentMode = await Settings.GetEntrapmentModeAsync();
        _multiJumpGraceSeconds = await Settings.GetMultiJumpGraceSecondsAsync();
        RefreshGames();
        GameService.GameUpdated += OnGameUpdated;
    }

    private string GetUserName(int userId)
    {
        if (userId <= 0) return "";
        return _userNames.TryGetValue(userId, out var name) ? name : "";
    }

    public void Dispose()
    {
        GameService.GameUpdated -= OnGameUpdated;
    }

    private void OnGameUpdated(string _)
    {
        RefreshGames();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshGames()
    {
        _games = GameService.ListGames();
    }

    private async Task SaveSettings()
    {
        _settingsMessage = "";
        var ok1 = await Settings.UpdateMaxTimeoutMinsAsync(_maxTimeoutMins);
        var ok2 = await Settings.UpdateReaperPeriodSecondsAsync(_reaperPeriodSeconds);
        var ok3 = await Settings.UpdateLastMoveHighlightColorAsync(_lastMoveHighlightColor);
        var ok4 = await Settings.UpdateEntrapmentModeAsync(_entrapmentMode);
        var ok5 = await Settings.UpdateMultiJumpGraceSecondsAsync(_multiJumpGraceSeconds);
        _settingsMessage = (ok1 && ok2 && ok3 && ok4 && ok5) ? "Saved." : "Invalid value.";
    }

    private static string FormatAge(TimeSpan ts)
    {
        if (ts < TimeSpan.Zero) ts = TimeSpan.Zero;

        if (ts.TotalHours >= 1)
        {
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        }
        return $"{ts.Minutes}m {ts.Seconds}s";
    }

    private static string FormatPlayer(int? userId, bool connected)
    {
        if (!connected) return "(open)";
        return userId.HasValue ? $"{userId.Value}" : "(connected)";
    }

    private void StartNewGame()
    {
        Nav.NavigateTo($"/drafts?creator={_creatorPlayerNumber}&admin=1");
    }

    private async Task OnChangePin()
    {
        _pinMessage = "";

        var userId = GetCurrentUserId();
        if (!userId.HasValue)
        {
            _pinMessage = "No player id.";
            return;
        }

        var ok = await Auth.ChangePinAsync(userId.Value, (_currentPin ?? "").Trim(), (_newPin ?? "").Trim());
        _pinMessage = ok ? "PIN changed." : "Failed (check current PIN and new PIN format).";
        if (ok)
        {
            _currentPin = "";
            _newPin = "";
        }
    }

    private int? GetCurrentUserId()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        var raw = user?.FindFirst("uid")?.Value;
        return int.TryParse(raw, out var id) ? id : null;
    }
}
