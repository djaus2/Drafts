@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@using Drafts.Services
@using System.Text.Json
@inject EnhancedVoiceChatService VoiceChatService
@inject IJSRuntime JS
@inject AdminVoiceSettingsService AdminVoiceSettings
@inject AuthService Auth

<style>
    .voice-settings-panel {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        padding: 20px;
        color: white;
        max-width: 500px;
        margin: 20px auto;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .settings-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    }

    .settings-title {
        font-size: 18px;
        font-weight: 600;
        margin: 0;
    }

    .close-btn {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        border-radius: 50%;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .close-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: scale(1.1);
    }

    .settings-section {
        margin-bottom: 20px;
    }

    .section-title {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 10px;
        opacity: 0.9;
    }

    .setting-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
        padding: 8px 0;
    }

    .setting-label {
        font-size: 14px;
        flex: 1;
    }

    .setting-control {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .toggle-switch {
        position: relative;
        width: 50px;
        height: 24px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        cursor: pointer;
        transition: background 0.3s ease;
    }

    .toggle-switch.active {
        background: #4CAF50;
    }

    .toggle-switch::after {
        content: '';
        position: absolute;
        top: 2px;
        left: 2px;
        width: 20px;
        height: 20px;
        background: white;
        border-radius: 50%;
        transition: transform 0.3s ease;
    }

    .toggle-switch.active::after {
        transform: translateX(26px);
    }

    .slider-control {
        width: 120px;
        height: 4px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 2px;
        outline: none;
        -webkit-appearance: none;
    }

    .slider-control::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 16px;
        height: 16px;
        background: white;
        border-radius: 50%;
        cursor: pointer;
    }

    .slider-control::-moz-range-thumb {
        width: 16px;
        height: 16px;
        background: white;
        border-radius: 50%;
        cursor: pointer;
        border: none;
    }

    .slider-value {
        font-size: 12px;
        min-width: 40px;
        text-align: right;
    }

    .select-control {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 5px;
        color: white;
        padding: 6px 10px;
        font-size: 14px;
        min-width: 120px;
    }

    .select-control option {
        background: #333;
        color: white;
    }

    .quality-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        font-size: 12px;
    }

    .quality-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    .quality-excellent { background: #4CAF50; }
    .quality-good { background: #8BC34A; }
    .quality-fair { background: #FFC107; }
    .quality-poor { background: #FF5722; }

    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
        margin-top: 10px;
    }

    .metric-item {
        background: rgba(255, 255, 255, 0.1);
        padding: 8px;
        border-radius: 6px;
        font-size: 12px;
    }

    .metric-label {
        opacity: 0.8;
        margin-bottom: 2px;
    }

    .metric-value {
        font-weight: 600;
    }

    .test-controls {
        display: flex;
        gap: 10px;
        margin-top: 15px;
    }

    .test-btn {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        border-radius: 6px;
        padding: 8px 16px;
        color: white;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .test-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: translateY(-1px);
    }

    .test-btn.testing {
        background: #4CAF50;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
</style>

<div class="voice-settings-panel">
    <div class="settings-header">
        <h3 class="settings-title">Voice Settings</h3>
        <button class="close-btn" @onclick="ClosePanel" @ontouchend="ClosePanel">✕</button>
    </div>

    <!-- Audio Processing Settings -->
    <div class="settings-section">
        <div class="section-title">Audio Processing</div>
        
        <div class="setting-row">
            <span class="setting-label">Echo Cancellation</span>
            <div class="setting-control">
                <div class="toggle-switch @(echoCancellationEnabled ? "active" : "")" 
                     @onclick="ToggleEchoCancellation"></div>
            </div>
        </div>

        <div class="setting-row">
            <span class="setting-label">Noise Suppression</span>
            <div class="setting-control">
                <div class="toggle-switch @(noiseSuppressionEnabled ? "active" : "")" 
                     @onclick="ToggleNoiseSuppression"></div>
            </div>
        </div>

        <div class="setting-row">
            <span class="setting-label">Automatic Gain Control</span>
            <div class="setting-control">
                <div class="toggle-switch @(autoGainControlEnabled ? "active" : "")" 
                     @onclick="ToggleAutoGainControl"></div>
            </div>
        </div>

        <div class="setting-row">
            <span class="setting-label">Input Sensitivity</span>
            <div class="setting-control">
                <input type="range" class="slider-control" 
                       min="0" max="100" value="@inputSensitivity" 
                       @oninput="OnInputSensitivityChange" />
                <span class="slider-value">@inputSensitivity%</span>
            </div>
        </div>
    </div>

    <!-- Network Settings -->
    <div class="settings-section">
        <div class="section-title">Network</div>
        
        <div class="setting-row">
            <span class="setting-label">Adaptive Bitrate</span>
            <div class="setting-control">
                <div class="toggle-switch @(adaptiveBitrateEnabled ? "active" : "")" 
                     @onclick="ToggleAdaptiveBitrate"></div>
            </div>
        </div>

        <div class="setting-row">
            <span class="setting-label">Quality Priority</span>
            <div class="setting-control">
                <select class="select-control" @onchange="OnQualityPriorityChange">
                    <option value="quality" selected="@(qualityPriority == "quality")">Quality</option>
                    <option value="latency" selected="@(qualityPriority == "latency")">Low Latency</option>
                    <option value="bandwidth" selected="@(qualityPriority == "bandwidth")">Bandwidth</option>
                </select>
            </div>
        </div>

        <div class="setting-row">
            <span class="setting-label">Network Quality</span>
            <div class="setting-control">
                <div class="quality-indicator">
                    <div class="quality-dot @GetNetworkQualityClass()"></div>
                    <span>@GetNetworkQualityText()</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Performance Metrics -->
    <div class="settings-section">
        <div class="section-title">Performance</div>
        
        <div class="metrics-grid">
            <div class="metric-item">
                <div class="metric-label">Latency</div>
                <div class="metric-value">@currentLatency ms</div>
            </div>
            <div class="metric-item">
                <div class="metric-label">Packet Loss</div>
                <div class="metric-value">@packetLoss%</div>
            </div>
            <div class="metric-item">
                <div class="metric-label">CPU Usage</div>
                <div class="metric-value">@cpuUsage%</div>
            </div>
            <div class="metric-item">
                <div class="metric-label">Bitrate</div>
                <div class="metric-value">@currentBitrate kbps</div>
            </div>
        </div>
    </div>

    <!-- Testing -->
    <div class="settings-section">
        <div class="section-title">Audio Testing</div>
        
        <div class="test-controls">
            <button class="test-btn @(isTestingEcho ? "testing" : "")" 
                    @onclick="TestEchoCancellation">
                @(isTestingEcho ? "Testing..." : "Test Echo")
            </button>
            <button class="test-btn @(isTestingNoise ? "testing" : "")" 
                    @onclick="TestNoiseSuppression">
                @(isTestingNoise ? "Testing..." : "Test Noise")
            </button>
            <button class="test-btn @(isRecordingTest ? "testing" : "")" 
                    @onclick="TestAudioRecording">
                @(isRecordingTest ? "Recording..." : "Record Test")
            </button>
        </div>
        
        @if (!string.IsNullOrEmpty(echoTestResult))
        {
            <div class="test-result" style="margin-top: 10px; padding: 8px; border-radius: 4px; background: rgba(255,255,255,0.1); font-size: 14px;">
                @echoTestResult
            </div>
        }
        
        @if (!string.IsNullOrEmpty(noiseTestResult))
        {
            <div class="test-result" style="margin-top: 10px; padding: 8px; border-radius: 4px; background: rgba(255,255,255,0.1); font-size: 14px;">
                @noiseTestResult
            </div>
        }
        
        @if (!string.IsNullOrEmpty(recordingTestResult))
        {
            <div class="test-result" style="margin-top: 10px; padding: 8px; border-radius: 4px; background: rgba(255,255,255,0.1); font-size: 14px;">
                @recordingTestResult
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public bool IsAdminMode { get; set; } = false;

    // Audio Processing Settings
    private bool echoCancellationEnabled = true;
    private bool noiseSuppressionEnabled = true;
    private bool autoGainControlEnabled = true;
    private int inputSensitivity = 75;

    // Voice System Choice
    private bool useEnhancedVoiceChat = false;  // Default to classic voice system

    // Test Results
    private string echoTestResult = "";
    private string noiseTestResult = "";
    private string recordingTestResult = "";

    // Network Settings
    private bool adaptiveBitrateEnabled = true;
    private string qualityPriority = "quality";

    // Performance Metrics
    private double currentLatency = 0;
    private double packetLoss = 0;
    private double cpuUsage = 0;
    private int currentBitrate = 64;

    // Testing State
    private bool isTestingEcho = false;
    private bool isTestingNoise = false;
    private bool isRecordingTest = false;

    // Timer for metrics updates
    private System.Timers.Timer? _metricsTimer;

    protected override async Task OnInitializedAsync()
    {
        // Load saved settings
        await LoadSettings();

        // Start metrics updates
        _metricsTimer = new System.Timers.Timer(1000); // Update every second
        _metricsTimer.Elapsed += async (sender, e) => await UpdateMetrics();
        _metricsTimer.Start();
    }

    private async Task LoadSettings()
    {
        try
        {
            if (IsAdminMode)
            {
                // Load admin settings from database
                var adminSettings = await AdminVoiceSettings.GetAdminVoiceSettingsAsync();
                Console.WriteLine($"[VoiceSettings] Admin mode - received {adminSettings.Count} settings");
                ApplySettings(adminSettings);
                Console.WriteLine("[VoiceSettings] Loaded admin settings from database");
            }
            else
            {
                // Load player settings from localStorage (with admin defaults)
                await LoadPlayerSettingsWithDefaults();
                Console.WriteLine("[VoiceSettings] Loaded player settings from localStorage");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[VoiceSettings] Error loading settings: {ex.Message}");
            // Use defaults
            ApplyDefaultSettings();
        }
    }

    private async Task SaveSettings()
    {
        try
        {
            var settings = CreateSettingsDictionary();

            if (IsAdminMode)
            {
                // Save admin settings to database
                var success = await AdminVoiceSettings.SaveAdminVoiceSettingsAsync(settings);
                if (success)
                {
                    Console.WriteLine("[VoiceSettings] Admin settings saved to database");
                }
                else
                {
                    Console.WriteLine("[VoiceSettings] Failed to save admin settings");
                }
            }
            else
            {
                // Save player settings to localStorage only
                await SavePlayerSettingsToLocalStorage(settings);
                Console.WriteLine("[VoiceSettings] Player settings saved to localStorage");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[VoiceSettings] Error saving settings: {ex.Message}");
        }
    }

    private async Task LoadPlayerSettingsWithDefaults()
    {
        try
        {
            // First load admin defaults
            var adminDefaults = await AdminVoiceSettings.GetAdminVoiceSettingsAsync();
            
            // Then try to load player's localStorage settings
            var playerSettingsJson = await JS.InvokeAsync<string>("localStorage.getItem", "voiceSettings");
            Console.WriteLine($"[VoiceSettings] Loading from localStorage: {playerSettingsJson}");
            
            if (!string.IsNullOrWhiteSpace(playerSettingsJson))
            {
                var playerSettings = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(playerSettingsJson);
                Console.WriteLine($"[VoiceSettings] Loaded {playerSettings?.Count ?? 0} player settings from localStorage");
                ApplySettings(playerSettings);
            }
            else
            {
                Console.WriteLine("[VoiceSettings] No player settings in localStorage, using admin defaults");
                // Use admin defaults for new players
                ApplySettings(adminDefaults);
            }
        }
        catch
        {
            // Use admin defaults as fallback
            var adminDefaults = await AdminVoiceSettings.GetAdminVoiceSettingsAsync();
            ApplySettings(adminDefaults);
        }
    }

    private async Task SavePlayerSettingsToLocalStorage(Dictionary<string, object> settings)
    {
        var settingsJson = System.Text.Json.JsonSerializer.Serialize(settings);
        Console.WriteLine($"[VoiceSettings] Saving to localStorage: {settingsJson}");
        await JS.InvokeVoidAsync("localStorage.setItem", "voiceSettings", settingsJson);
        
        // Verify it was saved by reading it back
        var savedJson = await JS.InvokeAsync<string>("localStorage.getItem", "voiceSettings");
        Console.WriteLine($"[VoiceSettings] Verified localStorage contains: {savedJson}");
    }

    private void ApplySettings(Dictionary<string, object>? settings)
    {
        var stackTrace = new System.Diagnostics.StackTrace();
        var callingMethod = stackTrace.GetFrame(1)?.GetMethod()?.Name ?? "Unknown";
        Console.WriteLine($"[VoiceSettings] ApplySettings called by {callingMethod} with {settings?.Count ?? 0} settings");
        if (settings == null) 
        {
            Console.WriteLine("[VoiceSettings] Settings is null, using defaults");
            return;
        }

        Console.WriteLine($"[VoiceSettings] Settings keys: {string.Join(", ", settings.Keys)}");

        if (settings.TryGetValue("echoCancellationEnabled", out var echoVal))
        {
            if (echoVal is bool echoBool)
            {
                echoCancellationEnabled = echoBool;
                Console.WriteLine($"[VoiceSettings] echoCancellationEnabled = {echoBool} (bool)");
            }
            else if (echoVal is JsonElement echoElem)
            {
                var echoStr = echoElem.GetRawText();
                if (bool.TryParse(echoStr, out var echoBoolFromElem))
                {
                    echoCancellationEnabled = echoBoolFromElem;
                    Console.WriteLine($"[VoiceSettings] echoCancellationEnabled = {echoBoolFromElem} (JsonElement)");
                }
                else
                {
                    Console.WriteLine($"[VoiceSettings] echoCancellationEnabled - failed to parse: {echoStr}");
                }
            }
            else
            {
                Console.WriteLine($"[VoiceSettings] echoCancellationEnabled - unexpected type: {echoVal?.GetType().Name}");
            }
        }

        if (settings.TryGetValue("noiseSuppressionEnabled", out var noiseVal))
        {
            if (noiseVal is bool noiseBool)
            {
                noiseSuppressionEnabled = noiseBool;
                Console.WriteLine($"[VoiceSettings] noiseSuppressionEnabled = {noiseBool} (bool)");
            }
            else if (noiseVal is JsonElement noiseElem)
            {
                var noiseStr = noiseElem.GetRawText();
                if (bool.TryParse(noiseStr, out var noiseBoolFromElem))
                {
                    noiseSuppressionEnabled = noiseBoolFromElem;
                    Console.WriteLine($"[VoiceSettings] noiseSuppressionEnabled = {noiseBoolFromElem} (JsonElement)");
                }
                else
                {
                    Console.WriteLine($"[VoiceSettings] noiseSuppressionEnabled - failed to parse: {noiseStr}");
                }
            }
            else
            {
                Console.WriteLine($"[VoiceSettings] noiseSuppressionEnabled - unexpected type: {noiseVal?.GetType().Name}");
            }
        }

        if (settings.TryGetValue("autoGainControlEnabled", out var gainVal))
        {
            if (gainVal is bool gainBool)
            {
                autoGainControlEnabled = gainBool;
                Console.WriteLine($"[VoiceSettings] autoGainControlEnabled = {gainBool} (bool)");
            }
            else if (gainVal is JsonElement gainElem)
            {
                var gainStr = gainElem.GetRawText();
                if (bool.TryParse(gainStr, out var gainBoolFromElem))
                {
                    autoGainControlEnabled = gainBoolFromElem;
                    Console.WriteLine($"[VoiceSettings] autoGainControlEnabled = {gainBoolFromElem} (JsonElement)");
                }
                else
                {
                    Console.WriteLine($"[VoiceSettings] autoGainControlEnabled - failed to parse: {gainStr}");
                }
            }
            else
            {
                Console.WriteLine($"[VoiceSettings] autoGainControlEnabled - unexpected type: {gainVal?.GetType().Name}");
            }
        }

        if (settings.TryGetValue("inputSensitivity", out var sensVal) && sensVal is JsonElement sensElem && sensElem.TryGetInt32(out var sensInt))
        {
            inputSensitivity = sensInt;
            Console.WriteLine($"[VoiceSettings] inputSensitivity = {sensInt}");
        }

        if (settings.TryGetValue("adaptiveBitrateEnabled", out var adaptVal))
        {
            if (adaptVal is bool adaptBool)
            {
                adaptiveBitrateEnabled = adaptBool;
                Console.WriteLine($"[VoiceSettings] adaptiveBitrateEnabled = {adaptBool} (bool)");
            }
            else if (adaptVal is JsonElement adaptElem)
            {
                var adaptStr = adaptElem.GetRawText();
                if (bool.TryParse(adaptStr, out var adaptBoolFromElem))
                {
                    adaptiveBitrateEnabled = adaptBoolFromElem;
                    Console.WriteLine($"[VoiceSettings] adaptiveBitrateEnabled = {adaptBoolFromElem} (JsonElement)");
                }
                else
                {
                    Console.WriteLine($"[VoiceSettings] adaptiveBitrateEnabled - failed to parse: {adaptStr}");
                }
            }
            else
            {
                Console.WriteLine($"[VoiceSettings] adaptiveBitrateEnabled - unexpected type: {adaptVal?.GetType().Name}");
            }
        }

        if (settings.TryGetValue("qualityPriority", out var qualVal))
        {
            if (qualVal is string qualStr)
            {
                qualityPriority = qualStr;
                Console.WriteLine($"[VoiceSettings] qualityPriority = {qualStr} (string)");
            }
            else if (qualVal is JsonElement qualElem)
            {
                var qualStrFromElem = qualElem.GetString();
                if (!string.IsNullOrEmpty(qualStrFromElem))
                {
                    qualityPriority = qualStrFromElem;
                    Console.WriteLine($"[VoiceSettings] qualityPriority = {qualStrFromElem} (JsonElement)");
                }
                else
                {
                    Console.WriteLine($"[VoiceSettings] qualityPriority - failed to parse from JsonElement");
                }
            }
            else
            {
                Console.WriteLine($"[VoiceSettings] qualityPriority - unexpected type: {qualVal?.GetType().Name}");
            }
        }

        if (settings.TryGetValue("useEnhancedVoiceChat", out var enhancedVal) && enhancedVal is bool enhancedBool)
        {
            useEnhancedVoiceChat = enhancedBool;
            Console.WriteLine($"[VoiceSettings] useEnhancedVoiceChat = {enhancedBool}");
        }

        Console.WriteLine($"[VoiceSettings] Final settings applied - echo:{echoCancellationEnabled}, noise:{noiseSuppressionEnabled}, gain:{autoGainControlEnabled}, sensitivity:{inputSensitivity}, enhanced:{useEnhancedVoiceChat}");
    }

    private void ApplyDefaultSettings()
    {
        echoCancellationEnabled = true;
        noiseSuppressionEnabled = true;
        autoGainControlEnabled = true;
        inputSensitivity = 75;
        adaptiveBitrateEnabled = true;
        qualityPriority = "quality";
        useEnhancedVoiceChat = false;  // Default to classic voice system
    }

    private Dictionary<string, object> CreateSettingsDictionary()
    {
        Console.WriteLine($"[VoiceSettings] CreateSettingsDictionary - echo:{echoCancellationEnabled}, noise:{noiseSuppressionEnabled}, gain:{autoGainControlEnabled}, sensitivity:{inputSensitivity}, adaptive:{adaptiveBitrateEnabled}, quality:{qualityPriority}, enhanced:{useEnhancedVoiceChat}");
        return new Dictionary<string, object>
        {
            { "echoCancellationEnabled", echoCancellationEnabled },
            { "noiseSuppressionEnabled", noiseSuppressionEnabled },
            { "autoGainControlEnabled", autoGainControlEnabled },
            { "inputSensitivity", inputSensitivity },
            { "adaptiveBitrateEnabled", adaptiveBitrateEnabled },
            { "qualityPriority", qualityPriority },
            { "useEnhancedVoiceChat", useEnhancedVoiceChat }
        };
    }

    // Audio Processing Toggles
    private async Task ToggleEchoCancellation()
    {
        echoCancellationEnabled = !echoCancellationEnabled;
        Console.WriteLine($"[VoiceSettings] ToggleEchoCancellation - new value: {echoCancellationEnabled}");
        // TODO: Implement actual JavaScript setEchoCancellation when available
        await SaveSettings();
    }

    private async Task ToggleNoiseSuppression()
    {
        noiseSuppressionEnabled = !noiseSuppressionEnabled;
        // TODO: Implement actual JavaScript setNoiseSuppression when available
        await SaveSettings();
    }

    private async Task ToggleAutoGainControl()
    {
        autoGainControlEnabled = !autoGainControlEnabled;
        // TODO: Implement actual JavaScript setAutoGainControl when available
        await SaveSettings();
    }

    private async Task OnInputSensitivityChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
        {
            inputSensitivity = value;
            // TODO: Implement actual JavaScript setInputSensitivity when available
            await SaveSettings();
        }
    }

    // Network Settings
    private async Task ToggleAdaptiveBitrate()
    {
        adaptiveBitrateEnabled = !adaptiveBitrateEnabled;
        // TODO: Implement actual JavaScript setAdaptiveBitrate when available
        await SaveSettings();
    }

    private async Task OnQualityPriorityChange(ChangeEventArgs e)
    {
        qualityPriority = e.Value?.ToString() ?? "quality";
        // TODO: Implement actual JavaScript setQualityPriority when available
        await SaveSettings();
    }

    // Metrics Updates
    private async Task UpdateMetrics()
    {
        try
        {
            // TODO: Implement actual JavaScript getVoiceMetrics when available
            // var metrics = await JS.InvokeAsync<object>("getVoiceMetrics");
            // Parse metrics and update state
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Handle error
        }
    }

    // Testing Methods
    private async Task TestEchoCancellation()
    {
        isTestingEcho = true;
        echoTestResult = "";
        StateHasChanged();

        try
        {
            // Simulate echo cancellation test
            await Task.Delay(3000); // Test duration
            
            // Simulate test result
            var random = new Random();
            var echoLevel = random.Next(10, 95);
            
            if (echoLevel < 30)
                echoTestResult = "✅ Excellent echo cancellation detected";
            else if (echoLevel < 60)
                echoTestResult = "⚠️ Moderate echo detected - consider adjusting settings";
            else
                echoTestResult = "❌ High echo detected - enable echo cancellation";
                
            // TODO: Implement actual JavaScript test when available
        }
        catch
        {
            echoTestResult = "❌ Test failed - please check microphone access";
        }
        finally
        {
            isTestingEcho = false;
            StateHasChanged();
        }
    }

    private async Task TestNoiseSuppression()
    {
        isTestingNoise = true;
        noiseTestResult = "";
        StateHasChanged();

        try
        {
            // Simulate noise suppression test
            await Task.Delay(3000); // Test duration
            
            // Simulate test result
            var random = new Random();
            var noiseLevel = random.Next(5, 85);
            
            if (noiseLevel < 25)
                noiseTestResult = "✅ Excellent noise suppression working";
            else if (noiseLevel < 50)
                noiseTestResult = "⚠️ Moderate background noise detected";
            else
                noiseTestResult = "❌ High background noise - enable noise suppression";
                
            // TODO: Implement actual JavaScript test when available
        }
        catch
        {
            noiseTestResult = "❌ Test failed - please check microphone access";
        }
        finally
        {
            isTestingNoise = false;
            StateHasChanged();
        }
    }

    private async Task TestAudioRecording()
    {
        isRecordingTest = true;
        recordingTestResult = "";
        StateHasChanged();

        try
        {
            // Simulate audio recording test
            await Task.Delay(5000); // Test duration
            
            // Simulate test result
            var random = new Random();
            var audioQuality = random.Next(20, 95);
            
            if (audioQuality > 75)
                recordingTestResult = "✅ Excellent audio quality detected";
            else if (audioQuality > 50)
                recordingTestResult = "⚠️ Good audio quality - consider adjusting sensitivity";
            else if (audioQuality > 25)
                recordingTestResult = "⚠️ Low audio volume - increase input sensitivity";
            else
                recordingTestResult = "❌ Very low audio detected - check microphone";
                
            // TODO: Implement actual JavaScript test when available
        }
        catch
        {
            recordingTestResult = "❌ Recording failed - please check microphone permissions";
        }
        finally
        {
            isRecordingTest = false;
            StateHasChanged();
        }
    }

    // UI Helpers
    private string GetNetworkQualityClass()
    {
        if (currentLatency < 50 && packetLoss < 1) return "quality-excellent";
        if (currentLatency < 100 && packetLoss < 2) return "quality-good";
        if (currentLatency < 200 && packetLoss < 5) return "quality-fair";
        return "quality-poor";
    }

    private string GetNetworkQualityText()
    {
        if (currentLatency < 50 && packetLoss < 1) return "Excellent";
        if (currentLatency < 100 && packetLoss < 2) return "Good";
        if (currentLatency < 200 && packetLoss < 5) return "Fair";
        return "Poor";
    }

    private async Task ClosePanel()
    {
        await OnClose.InvokeAsync();
    }

    public void Dispose()
    {
        _metricsTimer?.Dispose();
    }
}
